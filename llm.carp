(load "git@github.com:carpentry-org/http-client@0.2.1")
(load "git@github.com:carpentry-org/json@0.3.0")

(doc Role "is the role of a chat message. `System` for instructions, `User`
for user input, `Assistant` for model responses, `Tool` for tool result
messages.")
(deftype Role
  (System [])
  (User [])
  (Assistant [])
  (Tool []))

(doc ImageContent "represents an image to include in a message.

- `media-type`: the MIME type (e.g. `\"image/png\"`, `\"image/jpeg\"`)
- `data`: base64-encoded image data")
(deftype ImageContent [media-type String
                       data String])

(doc ToolDef "defines a tool the model can call.

- `name`: the tool name the model uses to invoke it
- `description`: natural-language description the model sees
- `parameters`: a JSON Schema describing the tool's arguments")
(deftype ToolDef [name String
                  description String
                  parameters JSON])

(doc ToolCall "represents a tool invocation from the model.

- `id`: the provider-assigned call ID (used to correlate results back).
  Empty for Gemini, which doesn't use call IDs.
- `name`: the tool name the model is calling
- `arguments`: the JSON-encoded argument object as a string")
(deftype ToolCall [id String
                   name String
                   arguments String])

(doc Message "a single chat message in a conversation.

- `role`: who the message is from
- `content`: the text content
- `tool-calls`: non-empty for assistant messages that invoke tools
- `tool-call-id`: non-empty for tool result messages (role = `Tool`)
- `images`: images to include (only meaningful for user messages)

Use the constructors in the `Message` module instead of `Message.init`
directly.")
(deftype Message
  [role Role
   content String
   tool-calls (Array ToolCall)
   tool-call-id String
   images (Array ImageContent)])

(doc format-text "format-mode for plain text responses (no constraint).")
(def format-text 0)
(doc format-json "format-mode for responses constrained to any valid JSON.")
(def format-json 1)
(doc format-json-schema
  "format-mode for responses constrained to a JSON schema.")
(def format-json-schema 2)

(doc soh-prefix "returns a SOH (0x01) byte string used to tag thinking/reasoning
tokens in streaming responses, so callers can distinguish them from content
tokens.")
(defn soh-prefix [] (String.from-chars &[(Char.from-int 1)]))

(doc LLMRequest "a chat request to an LLM provider.

Build with `LLM.chat-request`, `LLM.chat-request-with-tools`,
`LLM.chat-request-json`, or `LLM.chat-request-with-schema` rather than
constructing directly. Use the auto-generated `LLMRequest.set-*` functions
to set optional sampling parameters (e.g. `(LLMRequest.set-top-p req 0.9)`).

- `model`: provider-specific model identifier
- `messages`: the conversation history
- `max-tokens`: maximum output tokens
- `temperature`: sampling temperature (0.0 to 2.0)
- `tools`: tool definitions (empty array if none)
- `format-mode`: `format-text`, `format-json`, or `format-json-schema`
- `format-schema`: JSON schema for structured output (used when mode is
  `format-json-schema`)
- `top-p`: nucleus sampling threshold (0.0 to 1.0); negative means unset.
  Supported by all providers.
- `top-k`: top-k sampling (positive integer); negative means unset.
  Supported by Anthropic, Ollama, and Gemini (ignored by OpenAI).
- `frequency-penalty`: penalise repeated tokens (-2.0 to 2.0); values
  below -3.0 mean unset. Supported by OpenAI and Ollama.
- `presence-penalty`: penalise tokens already present (-2.0 to 2.0);
  values below -3.0 mean unset. Supported by OpenAI and Ollama.
- `seed`: deterministic sampling seed (non-negative integer); negative
  means unset. Supported by OpenAI and Ollama.")
(deftype LLMRequest
  [model String
   messages (Array Message)
   max-tokens Int
   temperature Double
   tools (Array ToolDef)
   format-mode Int
   format-schema JSON
   top-p Double
   top-k Int
   frequency-penalty Double
   presence-penalty Double
   seed Int])

(doc LLMResponse "a parsed response from an LLM provider.

- `content`: the text content of the response (may be empty if the model
  called tools instead)
- `stop-reason`: provider-specific reason the generation ended
- `input-tokens`: tokens consumed by the prompt
- `output-tokens`: tokens generated
- `tool-calls`: tool calls the model wants to make (empty if none)")
(deftype LLMResponse
  [content String
   stop-reason String
   input-tokens Int
   output-tokens Int
   tool-calls (Array ToolCall)])

(doc LLMError "represents an error from an LLM operation.

- `Transport`: connection, DNS, or network error
- `Api`: provider returned an error response (HTTP status, error type, message)")
(deftype LLMError
  (Transport [String])
  (Api [Int String String]))

(defmodule LLMError
  (doc str "formats an `LLMError` as a human-readable string.")
  (defn str [e]
    (match-ref e
      (LLMError.Transport msg) @msg
      (LLMError.Api code typ msg)
        (String.concat &[@"API error " @&(Int.str @code) @" (" @typ @"): " @msg])))
  (implements str LLMError.str))

(doc StreamEvent "represents a single event from a streaming LLM response.

- `Text`: a text delta (partial content token)
- `ToolCallEvent`: a complete tool call extracted from the stream

Use `LlmStream.poll-event` to receive these events. Returns
`(Maybe StreamEvent)` — `Nothing` when the stream is finished.")
(deftype StreamEvent
  (Text [String])
  (ToolCallEvent [ToolCall]))

; Internal: what a single SSE/NDJSON line parsed to.
(deftype StreamChunk
  (ChunkText [String])
  (ChunkToolStart [String String String])
  (ChunkToolDelta [String])
  (ChunkToolEnd [])
  (ChunkToolFull [ToolCall])
  (ChunkDone [])
  (ChunkSkip []))

(doc ProviderConfig "configuration for an LLM provider.

Build with `LLM.anthropic`, `LLM.openai`, `LLM.ollama`, or `LLM.gemini`
rather than constructing directly.

- `name`: one of `\"anthropic\"`, `\"openai\"`, `\"ollama\"`, `\"gemini\"`
- `base-url`: the API base URL
- `api-key`: the API key (empty for Ollama)
- `api-version`: used only by Anthropic (e.g. `\"2023-06-01\"`)")
(deftype ProviderConfig
  [name String
   base-url String
   api-key String
   api-version String])

(defmodule Role
  (doc str "returns the wire-format string for a role (`\"system\"`, `\"user\"`,
`\"assistant\"`, or `\"tool\"`).")
  (defn str [r]
    (match-ref r
      (Role.System) @"system"
      (Role.User) @"user"
      (Role.Assistant) @"assistant"
      (Role.Tool) @"tool"))
  (implements str Role.str))

(defmodule Message
  (doc user "creates a user message.")
  (defn user [s] (Message.init (Role.User) @s [] @"" []))

  (doc assistant "creates an assistant message.")
  (defn assistant [s] (Message.init (Role.Assistant) @s [] @"" []))

  (doc system "creates a system message.")
  (defn system [s] (Message.init (Role.System) @s [] @"" []))

  (doc tool-result "creates a tool result message for the given tool call ID.")
  (defn tool-result [call-id content]
    (Message.init (Role.Tool) @content [] @call-id []))

  (doc from-response "converts an LLMResponse into an assistant message,
preserving any tool calls for conversation history.")
  (defn from-response [r]
    (Message.init (Role.Assistant)
                  @(LLMResponse.content r)
                  @(LLMResponse.tool-calls r)
                  @""
                  []))

  (doc user-with-image "creates a user message with text and images.
Each image is an `ImageContent` with a MIME type and base64-encoded data.")
  (defn user-with-image [s images] (Message.init (Role.User) @s [] @"" images))

  (doc to-json "converts a message to a JSON object with role and content keys.
Includes tool_calls for assistant tool call messages, and tool_call_id for
tool result messages. When images are present, content is serialized as an
array of content parts (OpenAI format).")
  (defn to-json [m]
    (let [content-val (if (> (Array.length (Message.images m)) 0)
            (let [text-part [(Box.init
                               (JSON.obj
                                 [(JSON.entry @"type" (JSON.Str @"text"))
                                  (JSON.entry @"text"
                                              (JSON.Str @(Message.content m)))]))]
                  img-parts (Array.copy-map
                    &(fn [img]
                      (Box.init
                        (JSON.obj
                          [(JSON.entry @"type" (JSON.Str @"image_url"))
                           (JSON.entry @"image_url"
                                       (JSON.obj
                                         [(JSON.entry @"url"
                                                      (JSON.Str
                                                        (String.concat
                                                          &[@"data:"
                                                            @(ImageContent.media-type img)
                                                            @";base64,"
                                                            @(ImageContent.data img)])))]))])))
                    (Message.images m))]
              (JSON.Arr (Array.concat &[text-part img-parts])))
            (JSON.Str @(Message.content m)))
          base [(JSON.entry @"role" (JSON.Str (Role.str (Message.role m))))
                (JSON.entry @"content" content-val)]
          with-tool-id (if (> (String.length (Message.tool-call-id m)) 0)
            (Array.push-back base
                             (JSON.entry @"tool_call_id"
                                         (JSON.Str @(Message.tool-call-id m))))
            base)
          with-calls (llm-append-tool-calls-entry with-tool-id
                                                  (Message.tool-calls m))]
      (JSON.obj with-calls))))

; `llm-`/`gemini-` prefixed top-level functions are internal implementation
; detail, shared across the provider modules.

(defn llm-tooldef-to-openai-json [td]
  (JSON.obj
    [(JSON.entry @"type" (JSON.Str @"function"))
     (JSON.entry @"function"
                 (JSON.obj
                   [(JSON.entry @"name" (JSON.Str @(ToolDef.name td)))
                    (JSON.entry @"description"
                                (JSON.Str @(ToolDef.description td)))
                    (JSON.entry @"parameters" @(ToolDef.parameters td))]))]))

(defn llm-parse-openai-tool-calls [j]
  (match (JSON.get j "tool_calls")
    (Maybe.Just arr)
      (match (JSON.as-arr &arr)
        (Maybe.Just boxes)
          (Array.copy-map
            &(fn [bx]
              (let [tc (Box.peek bx)]
                (ToolCall.init (llm-json-str tc &[@"id"])
                               (llm-json-str tc &[@"function" @"name"])
                               (match (JSON.get-in tc
                                                   &[@"function" @"arguments"])
                                 (Maybe.Just args) (llm-json-to-str &args)
                                 _ @""))))
            &boxes)
        _ [])
    _ []))

(defn llm-messages-to-json [msgs]
  (JSON.Arr (Array.copy-map &(fn [m] (Box.init (Message.to-json m))) msgs)))

(defn llm-tool-call-to-json [tc]
  (let [args-json (match (JSON.parse (ToolCall.arguments tc))
          (Result.Success j) j
          _ (JSON.Str @(ToolCall.arguments tc)))]
    (Box.init
      (JSON.obj
        [(JSON.entry @"id" (JSON.Str @(ToolCall.id tc)))
         (JSON.entry @"type" (JSON.Str @"function"))
         (JSON.entry @"function"
                     (JSON.obj
                       [(JSON.entry @"name" (JSON.Str @(ToolCall.name tc)))
                        (JSON.entry @"arguments" args-json)]))]))))

(defn llm-tool-calls-to-json [tcs]
  (JSON.Arr (Array.copy-map &llm-tool-call-to-json tcs)))

(defn llm-append-tool-calls-entry [entries tcs]
  (if (> (Array.length tcs) 0)
    (Array.push-back entries
                     (JSON.entry @"tool_calls" (llm-tool-calls-to-json tcs)))
    entries))

(defn llm-anthropic-tool-use-block [tc]
  (let [inp (match (JSON.parse (ToolCall.arguments tc))
          (Result.Success j) j
          _ (JSON.Str @(ToolCall.arguments tc)))]
    (Box.init
      (JSON.obj
        [(JSON.entry @"type" (JSON.Str @"tool_use"))
         (JSON.entry @"id" (JSON.Str @(ToolCall.id tc)))
         (JSON.entry @"name" (JSON.Str @(ToolCall.name tc)))
         (JSON.entry @"input" inp)]))))

(defn llm-message-to-anthropic-json [m]
  (cond
    ; Tool result message -> role: user, content: [{type: tool_result, ...}]
    (> (String.length (Message.tool-call-id m)) 0)
    (JSON.obj
      [(JSON.entry @"role" (JSON.Str @"user"))
       (JSON.entry @"content"
                   (JSON.Arr
                     [(Box.init
                        (JSON.obj
                          [(JSON.entry @"type" (JSON.Str @"tool_result"))
                           (JSON.entry @"tool_use_id"
                                       (JSON.Str @(Message.tool-call-id m)))
                           (JSON.entry @"content"
                                       (JSON.Str @(Message.content m)))]))]))])
    ; Assistant message with tool calls -> content blocks with tool_use
    (> (Array.length (Message.tool-calls m)) 0)
    (let [text-parts (if (> (String.length (Message.content m)) 0)
            [(Box.init
               (JSON.obj
                 [(JSON.entry @"type" (JSON.Str @"text"))
                  (JSON.entry @"text" (JSON.Str @(Message.content m)))]))]
            [])
          tool-parts (Array.copy-map &llm-anthropic-tool-use-block
                                     (Message.tool-calls m))]
      (JSON.obj
        [(JSON.entry @"role" (JSON.Str @"assistant"))
         (JSON.entry @"content"
                     (JSON.Arr (Array.concat &[text-parts tool-parts])))]))
    ; Regular message (user/assistant/system without tool calls)
    (let [content-val (if (> (Array.length (Message.images m)) 0)
            (let [text-part [(Box.init
                               (JSON.obj
                                 [(JSON.entry @"type" (JSON.Str @"text"))
                                  (JSON.entry @"text"
                                              (JSON.Str @(Message.content m)))]))]
                  img-parts (Array.copy-map
                    &(fn [img]
                      (Box.init
                        (JSON.obj
                          [(JSON.entry @"type" (JSON.Str @"image"))
                           (JSON.entry @"source"
                                       (JSON.obj
                                         [(JSON.entry @"type"
                                                      (JSON.Str @"base64"))
                                          (JSON.entry @"media_type"
                                                      (JSON.Str @(ImageContent.media-type img)))
                                          (JSON.entry @"data"
                                                      (JSON.Str @(ImageContent.data img)))]))])))
                    (Message.images m))]
              (JSON.Arr (Array.concat &[text-part img-parts])))
            (JSON.Str @(Message.content m)))]
      (JSON.obj
        [(JSON.entry @"role" (JSON.Str (Role.str (Message.role m))))
         (JSON.entry @"content" content-val)]))))

(defn llm-message-to-ollama-json [m]
  (let [base [(JSON.entry @"role" (JSON.Str (Role.str (Message.role m))))
              (JSON.entry @"content" (JSON.Str @(Message.content m)))]
        with-images (if (> (Array.length (Message.images m)) 0)
          (Array.push-back base
                           (JSON.entry @"images"
                                       (JSON.Arr
                                         (Array.copy-map
                                           &(fn [img]
                                             (Box.init (JSON.Str @(ImageContent.data img))))
                                           (Message.images m)))))
          base)
        with-tool-id (if (> (String.length (Message.tool-call-id m)) 0)
          (Array.push-back with-images
                           (JSON.entry @"tool_call_id"
                                       (JSON.Str @(Message.tool-call-id m))))
          with-images)
        with-calls (llm-append-tool-calls-entry with-tool-id
                                                (Message.tool-calls m))]
    (JSON.obj with-calls)))

(defn llm-filter-non-system [msgs]
  (Array.copy-filter
    &(fn [m] (match-ref (Message.role m) (Role.System) false _ true))
    msgs))

(defn llm-system-text [msgs]
  (let [sys-msgs (Array.copy-filter
          &(fn [m] (match-ref (Message.role m) (Role.System) true _ false))
          msgs)]
    (if (= (Array.length &sys-msgs) 0)
      (Maybe.Nothing)
      (Maybe.Just (String.join "
" &(Array.copy-map &(fn [m] @(Message.content m)) &sys-msgs))))))

(defn llm-json-to-str [j]
  (match (JSON.str j) (Result.Success s) s (Result.Error _) @""))

(defn llm-json-parse [s]
  (match (JSON.parse s)
    (Result.Success j) (Result.Success j)
    (Result.Error _) (Result.Error @"JSON parse error")))

(defn llm-transport-error [msg] (Result.Error (LLMError.Transport msg)))

(defn llm-api-error [code typ msg] (Result.Error (LLMError.Api code typ msg)))

(defn llm-parse-error-body [code body type-path msg-path]
  (match (llm-json-parse body)
    (Result.Success j)
      (llm-api-error code (llm-json-str &j type-path) (llm-json-str &j msg-path))
    _ (llm-api-error code @"unknown" @body)))

(defn llm-parse-error [provider code body]
  (cond
    (= provider "openai")
    (llm-parse-error-body code body &[@"error" @"type"] &[@"error" @"message"])
    (= provider "anthropic")
    (llm-parse-error-body code body &[@"error" @"type"] &[@"error" @"message"])
    (= provider "ollama")
    ; Ollama errors are just `{"error": "message"}` with no structured type
    (match (llm-json-parse body)
      (Result.Success j)
        (llm-api-error code @"error" (llm-json-str &j &[@"error"]))
      _ (llm-api-error code @"unknown" @body))
    (= provider "gemini")
    (llm-parse-error-body code body &[@"error" @"status"] &[@"error" @"message"])
    (llm-api-error code @"unknown" @body)))

(defn llm-json-int [j keys]
  (match (JSON.get-in j keys)
    (Maybe.Just n) (Double.to-int (Maybe.from (JSON.as-num &n) 0.0))
    _ 0))

(defn llm-json-str [j keys]
  (match (JSON.get-in j keys)
    (Maybe.Just v) (Maybe.from (JSON.as-str &v) @"")
    _ @""))

(defmodule OpenAI
  (hidden add-format)
  (private add-format)
  (defn add-format [entries req]
    (cond
      (= @(LLMRequest.format-mode req) format-json)
        (Array.push-back entries
                         (JSON.entry @"response_format"
                                     (JSON.obj
                                       [(JSON.entry @"type"
                                                    (JSON.Str @"json_object"))])))
      (= @(LLMRequest.format-mode req) format-json-schema)
        (Array.push-back entries
                         (JSON.entry @"response_format"
                                     (JSON.obj
                                       [(JSON.entry @"type"
                                                    (JSON.Str @"json_schema"))
                                        (JSON.entry @"json_schema"
                                                    (JSON.obj
                                                      [(JSON.entry @"name"
                                                                   (JSON.Str @"result"))
                                                       (JSON.entry @"strict"
                                                                   (JSON.Bool true))
                                                       (JSON.entry @"schema"
                                                                   @(LLMRequest.format-schema req))]))])))
      entries))

  (hidden body)
  (private body)
  (defn body [req stream?]
    (let [msgs (llm-messages-to-json (LLMRequest.messages req))
          base [(JSON.entry @"model" (JSON.Str @(LLMRequest.model req)))
                (JSON.entry @"messages" msgs)
                (JSON.entry @"max_tokens"
                            (JSON.Num
                              (Double.from-int @(LLMRequest.max-tokens req))))
                (JSON.entry @"temperature"
                            (JSON.Num @(LLMRequest.temperature req)))]
          with-stream (if stream?
            (Array.push-back base (JSON.entry @"stream" (JSON.Bool true)))
            base)
          with-tools (if (> (Array.length (LLMRequest.tools req)) 0)
            (Array.push-back with-stream
                             (JSON.entry @"tools"
                                         (JSON.Arr
                                           (Array.copy-map
                                             &(fn [td]
                                               (Box.init (llm-tooldef-to-openai-json td)))
                                             (LLMRequest.tools req)))))
            with-stream)
          with-format (OpenAI.add-format with-tools req)
          with-top-p (if (>= @(LLMRequest.top-p req) 0.0)
            (Array.push-back with-format
                             (JSON.entry @"top_p"
                                         (JSON.Num @(LLMRequest.top-p req))))
            with-format)
          with-freq (if (> @(LLMRequest.frequency-penalty req) -3.0)
            (Array.push-back with-top-p
                             (JSON.entry @"frequency_penalty"
                                         (JSON.Num @(LLMRequest.frequency-penalty req))))
            with-top-p)
          with-pres (if (> @(LLMRequest.presence-penalty req) -3.0)
            (Array.push-back with-freq
                             (JSON.entry @"presence_penalty"
                                         (JSON.Num @(LLMRequest.presence-penalty req))))
            with-freq)
          entries (if (>= @(LLMRequest.seed req) 0)
            (Array.push-back with-pres
                             (JSON.entry @"seed"
                                         (JSON.Num (Double.from-int @(LLMRequest.seed req)))))
            with-pres)]
      (llm-json-to-str &(JSON.obj entries))))

  (defn build-request [req] (OpenAI.body req false))

  (defn parse-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [choice (match (JSON.get &j "choices")
                (Maybe.Just arr) (JSON.nth &arr 0)
                _ (Maybe.Nothing))
              content (match-ref &choice
                (Maybe.Just c) (llm-json-str c &[@"message" @"content"])
                (Maybe.Nothing) @"")
              stop-reason (match-ref &choice
                (Maybe.Just c) (llm-json-str c &[@"finish_reason"])
                (Maybe.Nothing) @"")
              tool-calls (match-ref &choice
                (Maybe.Just c)
                  (match (JSON.get c "message")
                    (Maybe.Just msg) (llm-parse-openai-tool-calls &msg)
                    _ [])
                (Maybe.Nothing) [])
              input-tokens (llm-json-int &j &[@"usage" @"prompt_tokens"])
              output-tokens (llm-json-int &j &[@"usage" @"completion_tokens"])]
          (Result.Success
            (LLMResponse.init content
                              stop-reason
                              input-tokens
                              output-tokens
                              tool-calls)))))

  (defn endpoint [_config] @"/v1/chat/completions")

  (defn headers [config body-len]
    (let [auth (String.concat &[@"Bearer " @(ProviderConfig.api-key config)])]
      {@"Content-Type" [@"application/json"]
       @"Authorization" [auth]
       @"Content-Length" [(Int.str body-len)]}))

  (defn build-stream-request [req] (OpenAI.body req true))

  (defn parse-delta [line]
    (cond
      (String.starts-with? line "data: [DONE]") (Maybe.Nothing)
      (String.starts-with? line "data: ")
        (let [json-str (String.byte-slice line 6 (String.length line))]
          (match (JSON.parse &json-str)
            (Result.Success j)
              (match (JSON.get &j "choices")
                (Maybe.Just arr)
                  (match (JSON.nth &arr 0)
                    (Maybe.Just choice)
                      (let [tok (llm-json-str &choice &[@"delta" @"content"])]
                        (if (> (String.length &tok) 0)
                          (Maybe.Just tok)
                          (let [think (llm-json-str &choice
                                                    &[@"delta" @"reasoning"])]
                            (if (> (String.length &think) 0)
                              (Maybe.Just (String.concat &[(soh-prefix) think]))
                              (Maybe.Nothing)))))
                    _ (Maybe.Nothing))
                _ (Maybe.Nothing))
            _ (Maybe.Nothing)))
      (Maybe.Nothing)))

  (defn parse-stream-event [line]
    (cond
      (String.starts-with? line "data: [DONE]") [(StreamChunk.ChunkDone)]
      (String.starts-with? line "data: ")
        (let [json-str (String.byte-slice line 6 (String.length line))]
          (match (JSON.parse &json-str)
            (Result.Success j)
              (match (JSON.get &j "choices")
                (Maybe.Just arr)
                  (match (JSON.nth &arr 0)
                    (Maybe.Just choice)
                      (let [tok (llm-json-str &choice &[@"delta" @"content"])]
                        (if (> (String.length &tok) 0)
                          [(StreamChunk.ChunkText tok)]
                          (match (JSON.get-in &choice &[@"delta" @"tool_calls"])
                            (Maybe.Just tcs-arr)
                              (match (JSON.as-arr &tcs-arr)
                                (Maybe.Just boxes)
                                  (let [chunks (Array.copy-map
                                          &(fn [bx]
                                            (let [tc (Box.peek bx)
                                                  id (llm-json-str tc &[@"id"])
                                                  name (llm-json-str tc
                                                                     &[@"function"
                                                                       @"name"])
                                                  args (llm-json-str tc
                                                                     &[@"function"
                                                                       @"arguments"])]
                                              (cond
                                                (> (String.length &id) 0)
                                                  (StreamChunk.ChunkToolStart id
                                                                              name
                                                                              args)
                                                (> (String.length &args) 0)
                                                  (StreamChunk.ChunkToolDelta args)
                                                (StreamChunk.ChunkSkip))))
                                          &boxes)]
                                    (if (> (Array.length &chunks) 0)
                                      chunks
                                      [(StreamChunk.ChunkSkip)]))
                                _ [(StreamChunk.ChunkSkip)])
                            _
                              (let [think (llm-json-str &choice
                                                        &[@"delta" @"reasoning"])]
                                (if (> (String.length &think) 0)
                                  [(StreamChunk.ChunkText (String.concat &[(soh-prefix)
                                                                           think]))]
                                  [(StreamChunk.ChunkSkip)])))))
                    _ [(StreamChunk.ChunkSkip)])
                _ [(StreamChunk.ChunkSkip)])
            _ [(StreamChunk.ChunkSkip)]))
      [(StreamChunk.ChunkSkip)])))

(defmodule Anthropic
  (hidden system-text)
  (private system-text)
  (defn system-text [req]
    (let [sys-base (Maybe.from (llm-system-text (LLMRequest.messages req)) @"")
          fmt-instruction (cond
            (= @(LLMRequest.format-mode req) format-json)
              @"You must respond with valid JSON only, no other text."
            (= @(LLMRequest.format-mode req) format-json-schema)
              (String.concat
                &[@"You must respond with valid JSON matching this schema, no other text:
"
                  (llm-json-to-str (LLMRequest.format-schema req))])
            @"")]
      (cond
        (= (String.length &fmt-instruction) 0) sys-base
        (= (String.length &sys-base) 0) fmt-instruction
        (String.concat &[sys-base @"

" fmt-instruction]))))

  (hidden body)
  (private body)
  (defn body [req stream?]
    (let [non-system (llm-filter-non-system (LLMRequest.messages req))
          msgs (JSON.Arr
            (Array.copy-map
              &(fn [m] (Box.init (llm-message-to-anthropic-json m)))
              &non-system))
          base [(JSON.entry @"model" (JSON.Str @(LLMRequest.model req)))
                (JSON.entry @"messages" msgs)
                (JSON.entry @"max_tokens"
                            (JSON.Num
                              (Double.from-int @(LLMRequest.max-tokens req))))
                (JSON.entry @"temperature"
                            (JSON.Num @(LLMRequest.temperature req)))]
          with-stream (if stream?
            (Array.push-back base (JSON.entry @"stream" (JSON.Bool true)))
            base)
          sys-text (Anthropic.system-text req)
          with-sys (if (> (String.length &sys-text) 0)
            (Array.push-back with-stream
                             (JSON.entry @"system" (JSON.Str sys-text)))
            with-stream)
          with-tools (if (> (Array.length (LLMRequest.tools req)) 0)
            (Array.push-back with-sys
                             (JSON.entry @"tools"
                                         (JSON.Arr
                                           (Array.copy-map
                                             &(fn [td]
                                               (Box.init
                                                 (JSON.obj
                                                   [(JSON.entry @"name"
                                                                (JSON.Str @(ToolDef.name td)))
                                                    (JSON.entry @"description"
                                                                (JSON.Str @(ToolDef.description td)))
                                                    (JSON.entry @"input_schema"
                                                                @(ToolDef.parameters td))])))
                                             (LLMRequest.tools req)))))
            with-sys)
          with-top-p (if (>= @(LLMRequest.top-p req) 0.0)
            (Array.push-back with-tools
                             (JSON.entry @"top_p"
                                         (JSON.Num @(LLMRequest.top-p req))))
            with-tools)
          entries (if (> @(LLMRequest.top-k req) 0)
            (Array.push-back with-top-p
                             (JSON.entry @"top_k"
                                         (JSON.Num
                                           (Double.from-int @(LLMRequest.top-k req)))))
            with-top-p)]
      (llm-json-to-str &(JSON.obj entries))))

  (defn build-request [req] (Anthropic.body req false))

  (defn parse-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [content (match (JSON.get &j "content")
                (Maybe.Just arr)
                  (match (JSON.as-arr &arr)
                    (Maybe.Just boxes)
                      (let [text-parts (Array.copy-filter
                              &(fn [bx]
                                (= &(llm-json-str (Box.peek bx) &[@"type"])
                                   "text"))
                              &boxes)]
                        (if (> (Array.length &text-parts) 0)
                          (llm-json-str
                            (Box.peek (Array.unsafe-nth &text-parts 0))
                            &[@"text"])
                          @""))
                    _ @"")
                _ @"")
              tool-calls (match (JSON.get &j "content")
                (Maybe.Just arr)
                  (match (JSON.as-arr &arr)
                    (Maybe.Just boxes)
                      (let [calls (Array.copy-filter
                              &(fn [bx]
                                (= &(llm-json-str (Box.peek bx) &[@"type"])
                                   "tool_use"))
                              &boxes)]
                        (Array.copy-map
                          &(fn [bx]
                            (let [tc (Box.peek bx)]
                              (ToolCall.init (llm-json-str tc &[@"id"])
                                             (llm-json-str tc &[@"name"])
                                             (match (JSON.get tc "input")
                                               (Maybe.Just inp)
                                                 (llm-json-to-str &inp)
                                               _ @""))))
                          &calls))
                    _ [])
                _ [])
              stop-reason (llm-json-str &j &[@"stop_reason"])
              input-tokens (llm-json-int &j &[@"usage" @"input_tokens"])
              output-tokens (llm-json-int &j &[@"usage" @"output_tokens"])]
          (Result.Success
            (LLMResponse.init content
                              stop-reason
                              input-tokens
                              output-tokens
                              tool-calls)))))

  (defn endpoint [_config] @"/v1/messages")

  (defn headers [config body-len]
    {@"Content-Type" [@"application/json"]
     @"x-api-key" [@(ProviderConfig.api-key config)]
     @"anthropic-version" [@(ProviderConfig.api-version config)]
     @"Content-Length" [(Int.str body-len)]})

  (defn build-stream-request [req] (Anthropic.body req true))

  (defn parse-delta [line]
    (if (String.starts-with? line "data: ")
      (let [json-str (String.byte-slice line 6 (String.length line))]
        (match (JSON.parse &json-str)
          (Result.Success j)
            (match (JSON.get &j "type")
              (Maybe.Just t)
                (if (= &(Maybe.from (JSON.as-str &t) @"") "content_block_delta")
                  (let [delta-type (llm-json-str &j &[@"delta" @"type"])]
                    (if (= &delta-type "thinking_delta")
                      (let [think (llm-json-str &j &[@"delta" @"thinking"])]
                        (if (> (String.length &think) 0)
                          (Maybe.Just (String.concat &[(soh-prefix) think]))
                          (Maybe.Nothing)))
                      (let [tok (llm-json-str &j &[@"delta" @"text"])]
                        (if (> (String.length &tok) 0)
                          (Maybe.Just tok)
                          (Maybe.Nothing)))))
                  (Maybe.Nothing))
              _ (Maybe.Nothing))
          _ (Maybe.Nothing)))
      (Maybe.Nothing)))

  (defn parse-stream-event [line]
    (if (String.starts-with? line "data: ")
      (let [json-str (String.byte-slice line 6 (String.length line))]
        (match (JSON.parse &json-str)
          (Result.Success j)
            (let [type-str (llm-json-str &j &[@"type"])]
              (cond
                (= &type-str "content_block_start")
                  (if (=
                      &(llm-json-str &j &[@"content_block" @"type"])
                      "tool_use")
                    [(StreamChunk.ChunkToolStart
                       (llm-json-str &j &[@"content_block" @"id"])
                       (llm-json-str &j &[@"content_block" @"name"])
                       @"")]
                    [(StreamChunk.ChunkSkip)])
                (= &type-str "content_block_delta")
                  (let [delta-type (llm-json-str &j &[@"delta" @"type"])]
                    (cond
                      (= &delta-type "text_delta")
                        [(StreamChunk.ChunkText (llm-json-str &j
                                                              &[@"delta" @"text"]))]
                      (= &delta-type "thinking_delta")
                        (let [think (llm-json-str &j &[@"delta" @"thinking"])]
                          (if (> (String.length &think) 0)
                            [(StreamChunk.ChunkText (String.concat &[(soh-prefix)
                                                                     think]))]
                            [(StreamChunk.ChunkSkip)]))
                      (= &delta-type "input_json_delta")
                        [(StreamChunk.ChunkToolDelta
                           (llm-json-str &j &[@"delta" @"partial_json"]))]
                      [(StreamChunk.ChunkSkip)]))
                (= &type-str "content_block_stop") [(StreamChunk.ChunkSkip)]
                (= &type-str "message_stop") [(StreamChunk.ChunkDone)]
                [(StreamChunk.ChunkSkip)]))
          _ [(StreamChunk.ChunkSkip)]))
      [(StreamChunk.ChunkSkip)])))

(defmodule Ollama
  (hidden body)
  (private body)
  (defn body [req stream?]
    (let [msgs (JSON.Arr
            (Array.copy-map
              &(fn [m] (Box.init (llm-message-to-ollama-json m)))
              (LLMRequest.messages req)))
          opt-base [(JSON.entry @"num_predict"
                                (JSON.Num
                                  (Double.from-int @(LLMRequest.max-tokens req))))
                    (JSON.entry @"temperature"
                                (JSON.Num @(LLMRequest.temperature req)))]
          opt-with-top-p (if (>= @(LLMRequest.top-p req) 0.0)
            (Array.push-back opt-base
                             (JSON.entry @"top_p"
                                         (JSON.Num @(LLMRequest.top-p req))))
            opt-base)
          opt-with-top-k (if (> @(LLMRequest.top-k req) 0)
            (Array.push-back opt-with-top-p
                             (JSON.entry @"top_k"
                                         (JSON.Num
                                           (Double.from-int @(LLMRequest.top-k req)))))
            opt-with-top-p)
          opt-with-freq (if (> @(LLMRequest.frequency-penalty req) -3.0)
            (Array.push-back opt-with-top-k
                             (JSON.entry @"frequency_penalty"
                                         (JSON.Num @(LLMRequest.frequency-penalty req))))
            opt-with-top-k)
          opt-with-pres (if (> @(LLMRequest.presence-penalty req) -3.0)
            (Array.push-back opt-with-freq
                             (JSON.entry @"presence_penalty"
                                         (JSON.Num @(LLMRequest.presence-penalty req))))
            opt-with-freq)
          opt-entries (if (>= @(LLMRequest.seed req) 0)
            (Array.push-back opt-with-pres
                             (JSON.entry @"seed"
                                         (JSON.Num (Double.from-int @(LLMRequest.seed req)))))
            opt-with-pres)
          opts (JSON.obj opt-entries)
          base [(JSON.entry @"model" (JSON.Str @(LLMRequest.model req)))
                (JSON.entry @"messages" msgs)
                (JSON.entry @"stream" (JSON.Bool stream?))
                (JSON.entry @"options" opts)]
          with-tools (if (> (Array.length (LLMRequest.tools req)) 0)
            (Array.push-back base
                             (JSON.entry @"tools"
                                         (JSON.Arr
                                           (Array.copy-map
                                             &(fn [td]
                                               (Box.init (llm-tooldef-to-openai-json td)))
                                             (LLMRequest.tools req)))))
            base)
          entries (cond
            (= @(LLMRequest.format-mode req) format-json)
              (Array.push-back with-tools
                               (JSON.entry @"format" (JSON.Str @"json")))
            (= @(LLMRequest.format-mode req) format-json-schema)
              (Array.push-back with-tools
                               (JSON.entry @"format"
                                           @(LLMRequest.format-schema req)))
            with-tools)]
      (llm-json-to-str &(JSON.obj entries))))

  (defn build-request [req] (Ollama.body req false))

  (defn parse-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [content (llm-json-str &j &[@"message" @"content"])
              tool-calls (match (JSON.get &j "message")
                (Maybe.Just msg) (llm-parse-openai-tool-calls &msg)
                _ [])
              stop-reason (llm-json-str &j &[@"done_reason"])
              input-tokens (llm-json-int &j &[@"prompt_eval_count"])
              output-tokens (llm-json-int &j &[@"eval_count"])]
          (Result.Success
            (LLMResponse.init content
                              stop-reason
                              input-tokens
                              output-tokens
                              tool-calls)))))

  (defn endpoint [_config] @"/api/chat")

  (defn headers [_config body-len]
    {@"Content-Type" [@"application/json"]
     @"Content-Length" [(Int.str body-len)]})

  (defn build-stream-request [req] (Ollama.body req true))

  (defn parse-delta [line]
    (match (JSON.parse line)
      (Result.Success j)
        (match (JSON.get &j "done")
          (Maybe.Just d)
            (if (Maybe.from (JSON.as-bool &d) false)
              (Maybe.Nothing)
              (let [tok (llm-json-str &j &[@"message" @"content"])]
                (if (> (String.length &tok) 0)
                  (Maybe.Just tok)
                  (let [think (llm-json-str &j &[@"message" @"thinking"])]
                    (if (> (String.length &think) 0)
                      (Maybe.Just (String.concat &[(soh-prefix) think]))
                      (Maybe.Nothing))))))
          _ (Maybe.Nothing))
      _ (Maybe.Nothing)))

  (defn parse-stream-event [line]
    (match (JSON.parse line)
      (Result.Success j)
        (match (JSON.get &j "done")
          (Maybe.Just d)
            (if (Maybe.from (JSON.as-bool &d) false)
              (let [tcs (match (JSON.get &j "message")
                      (Maybe.Just msg) (llm-parse-openai-tool-calls &msg)
                      _ [])]
                (if (> (Array.length &tcs) 0)
                  (Array.copy-map
                    &(fn [tc] (StreamChunk.ChunkToolFull @tc))
                    &tcs)
                  [(StreamChunk.ChunkDone)]))
              (let [tok (llm-json-str &j &[@"message" @"content"])]
                (if (> (String.length &tok) 0)
                  [(StreamChunk.ChunkText tok)]
                  (let [think (llm-json-str &j &[@"message" @"thinking"])]
                    (if (> (String.length &think) 0)
                      [(StreamChunk.ChunkText (String.concat &[(soh-prefix)
                                                               think]))]
                      [(StreamChunk.ChunkSkip)])))))
          _ [(StreamChunk.ChunkSkip)])
      _ [(StreamChunk.ChunkSkip)])))

(defn gemini-message-to-json [m]
  (match-ref (Message.role m)
    (Role.Tool)
    ; Gemini: tool results must be role "user" with functionResponse parts.
    ; tool-call-id stores the function name for Gemini (no call IDs).
    (let [resp-obj (match (JSON.parse (Message.content m))
            (Result.Success j) j
            _
              (JSON.obj [(JSON.entry @"result" (JSON.Str @(Message.content m)))]))]
      (JSON.obj
        [(JSON.entry @"role" (JSON.Str @"user"))
         (JSON.entry @"parts"
                     (JSON.Arr
                       [(Box.init
                          (JSON.obj
                            [(JSON.entry @"functionResponse"
                                         (JSON.obj
                                           [(JSON.entry @"name"
                                                        (JSON.Str @(Message.tool-call-id m)))
                                            (JSON.entry @"response" resp-obj)]))]))]))]))
    (Role.Assistant)
    ; Gemini uses "model" for assistant, and functionCall parts for tool calls.
    (let [text-part (if (> (String.length (Message.content m)) 0)
            [(Box.init
               (JSON.obj [(JSON.entry @"text" (JSON.Str @(Message.content m)))]))]
            (the (Array (Box JSON)) []))
          fc-parts (Array.copy-map
            &(fn [tc]
              (let [args-json (match (JSON.parse (ToolCall.arguments tc))
                      (Result.Success j) j
                      _ (JSON.Str @(ToolCall.arguments tc)))]
                (Box.init
                  (JSON.obj
                    [(JSON.entry @"functionCall"
                                 (JSON.obj
                                   [(JSON.entry @"name"
                                                (JSON.Str @(ToolCall.name tc)))
                                    (JSON.entry @"args" args-json)]))]))))
            (Message.tool-calls m))
          parts (Array.concat &[text-part fc-parts])]
      (JSON.obj
        [(JSON.entry @"role" (JSON.Str @"model"))
         (JSON.entry @"parts" (JSON.Arr parts))]))
    _
    ; User (system is filtered before reaching here)
    (let [text-part [(Box.init
                       (JSON.obj
                         [(JSON.entry @"text" (JSON.Str @(Message.content m)))]))]
          img-parts (Array.copy-map
            &(fn [img]
              (Box.init
                (JSON.obj
                  [(JSON.entry @"inlineData"
                               (JSON.obj
                                 [(JSON.entry @"mimeType"
                                              (JSON.Str @(ImageContent.media-type img)))
                                  (JSON.entry @"data"
                                              (JSON.Str @(ImageContent.data img)))]))])))
            (Message.images m))
          parts (Array.concat &[text-part img-parts])]
      (JSON.obj
        [(JSON.entry @"role" (JSON.Str @"user"))
         (JSON.entry @"parts" (JSON.Arr parts))]))))

(defmodule Gemini
  (hidden body)
  (private body)
  (defn body [req include-tools?]
    (let [non-system (the (Array Message)
                          (llm-filter-non-system (LLMRequest.messages req)))
          contents (JSON.Arr
            (Array.copy-map
              &(fn [m] (Box.init (gemini-message-to-json m)))
              &non-system))
          gen-base [(JSON.entry @"maxOutputTokens"
                                (JSON.Num
                                  (Double.from-int @(LLMRequest.max-tokens req))))
                    (JSON.entry @"temperature"
                                (JSON.Num @(LLMRequest.temperature req)))]
          gen-with-top-p (if (>= @(LLMRequest.top-p req) 0.0)
            (Array.push-back gen-base
                             (JSON.entry @"topP"
                                         (JSON.Num @(LLMRequest.top-p req))))
            gen-base)
          gen-with-top-k (if (> @(LLMRequest.top-k req) 0)
            (Array.push-back gen-with-top-p
                             (JSON.entry @"topK"
                                         (JSON.Num
                                           (Double.from-int @(LLMRequest.top-k req)))))
            gen-with-top-p)
          gen-with-mime (if (> @(LLMRequest.format-mode req) format-text)
            (Array.push-back gen-with-top-k
                             (JSON.entry @"responseMimeType"
                                         (JSON.Str @"application/json")))
            gen-with-top-k)
          gen-entries (if (= @(LLMRequest.format-mode req) format-json-schema)
            (Array.push-back gen-with-mime
                             (JSON.entry @"responseSchema"
                                         @(LLMRequest.format-schema req)))
            gen-with-mime)
          gen-config (JSON.obj gen-entries)
          base [(JSON.entry @"contents" contents)
                (JSON.entry @"generationConfig" gen-config)]
          with-sys (match (llm-system-text (LLMRequest.messages req))
            (Maybe.Just sys)
              (let [si (JSON.obj
                      [(JSON.entry @"parts"
                                   (JSON.Arr
                                     [(Box.init
                                        (JSON.obj [(JSON.entry @"text"
                                                               (JSON.Str sys))]))]))])]
                (Array.push-back base (JSON.entry @"systemInstruction" si)))
            (Maybe.Nothing) base)
          entries (if (and include-tools?
                           (> (Array.length (LLMRequest.tools req)) 0))
            (Array.push-back with-sys
                             (JSON.entry @"tools"
                                         (JSON.Arr
                                           [(Box.init
                                              (JSON.obj
                                                [(JSON.entry @"functionDeclarations"
                                                             (JSON.Arr
                                                               (Array.copy-map
                                                                 &(fn [td]
                                                                   (Box.init
                                                                     (JSON.obj
                                                                       [(JSON.entry @"name"
                                                                                    (JSON.Str @(ToolDef.name td)))
                                                                        (JSON.entry @"description"
                                                                                    (JSON.Str @(ToolDef.description td)))
                                                                        (JSON.entry @"parameters"
                                                                                    @(ToolDef.parameters td))])))
                                                                 (LLMRequest.tools req))))]))])))
            with-sys)]
      (llm-json-to-str &(JSON.obj entries))))

  (defn build-request [req] (Gemini.body req true))

  (defn parse-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [cand (match (JSON.get &j "candidates")
                (Maybe.Just arr) (JSON.nth &arr 0)
                _ (Maybe.Nothing))
              content (match-ref &cand
                (Maybe.Just c)
                  (match (JSON.get-in c &[@"content" @"parts"])
                    (Maybe.Just parts)
                      (match (JSON.nth &parts 0)
                        (Maybe.Just part) (llm-json-str &part &[@"text"])
                        _ @"")
                    _ @"")
                (Maybe.Nothing) @"")
              tool-calls (match-ref &cand
                (Maybe.Just c)
                  (match (JSON.get-in c &[@"content" @"parts"])
                    (Maybe.Just parts)
                      (match (JSON.as-arr &parts)
                        (Maybe.Just boxes)
                          (let [fc-parts (Array.copy-filter
                                  &(fn [bx]
                                    (match (JSON.get (Box.peek bx)
                                                     "functionCall")
                                      (Maybe.Just _) true
                                      _ false))
                                  &boxes)]
                            (Array.copy-map
                              &(fn [bx]
                                (let [fc (Box.peek bx)]
                                  (ToolCall.init @""
                                                 ; Gemini doesn't use call IDs
                                                 (llm-json-str fc
                                                               &[@"functionCall"
                                                                 @"name"])
                                                 (match (JSON.get-in fc
                                                                     &[@"functionCall"
                                                                       @"args"])
                                                   (Maybe.Just args)
                                                     (llm-json-to-str &args)
                                                   _ @""))))
                              &fc-parts))
                        _ [])
                    _ [])
                (Maybe.Nothing) [])
              stop-reason (match-ref &cand
                (Maybe.Just c) (llm-json-str c &[@"finishReason"])
                (Maybe.Nothing) @"")
              input-tokens (llm-json-int &j
                                         &[@"usageMetadata" @"promptTokenCount"])
              output-tokens (llm-json-int &j
                                          &[@"usageMetadata"
                                            @"candidatesTokenCount"])]
          (Result.Success
            (LLMResponse.init content
                              stop-reason
                              input-tokens
                              output-tokens
                              tool-calls)))))

  (defn endpoint [_config model]
    (String.concat &[@"/v1beta/models/" @model @":generateContent"]))

  (defn stream-endpoint [_config model]
    (String.concat
      &[@"/v1beta/models/" @model @":streamGenerateContent?alt=sse"]))

  (defn headers [config body-len]
    {@"Content-Type" [@"application/json"]
     @"x-goog-api-key" [@(ProviderConfig.api-key config)]
     @"Content-Length" [(Int.str body-len)]})

  (defn build-stream-request [req] (Gemini.body req true))

  (defn parse-delta [line]
    (if (String.starts-with? line "data: ")
      (let [json-str (String.byte-slice line 6 (String.length line))]
        (match (JSON.parse &json-str)
          (Result.Success j)
            (match (JSON.get &j "candidates")
              (Maybe.Just arr)
                (match (JSON.nth &arr 0)
                  (Maybe.Just cand)
                    (match (JSON.get-in &cand &[@"content" @"parts"])
                      (Maybe.Just parts)
                        (match (JSON.nth &parts 0)
                          (Maybe.Just part)
                            (let [tok (llm-json-str &part &[@"text"])
                                  is-thought (match (JSON.get &part "thought")
                                    (Maybe.Just v)
                                      (Maybe.from (JSON.as-bool &v) false)
                                    _ false)]
                              (if (> (String.length &tok) 0)
                                (if is-thought
                                  (Maybe.Just (String.concat &[(soh-prefix) tok]))
                                  (Maybe.Just tok))
                                (Maybe.Nothing)))
                          _ (Maybe.Nothing))
                      _ (Maybe.Nothing))
                  _ (Maybe.Nothing))
              _ (Maybe.Nothing))
          _ (Maybe.Nothing)))
      (Maybe.Nothing)))

  (defn parse-stream-event [line]
    (if (String.starts-with? line "data: ")
      (let [json-str (String.byte-slice line 6 (String.length line))]
        (match (JSON.parse &json-str)
          (Result.Success j)
            (match (JSON.get &j "candidates")
              (Maybe.Just arr)
                (match (JSON.nth &arr 0)
                  (Maybe.Just cand)
                    (let [has-finish (match (JSON.get &cand "finishReason")
                            (Maybe.Just _) true
                            _ false)]
                      (match (JSON.get-in &cand &[@"content" @"parts"])
                        (Maybe.Just parts)
                          (match (JSON.as-arr &parts)
                            (Maybe.Just boxes)
                              (let-do [chunks (the (Array StreamChunk) [])]
                                (for [i 0 (Array.length &boxes)]
                                  (let [part (Box.peek (Array.unsafe-nth &boxes
                                                                         i))]
                                    (match (JSON.get part "functionCall")
                                      (Maybe.Just fc)
                                        (set! chunks
                                              (Array.push-back chunks
                                                               (StreamChunk.ChunkToolFull
                                                                 (ToolCall.init @""
                                                                                (llm-json-str part
                                                                                              &[@"functionCall"
                                                                                                @"name"])
                                                                                (match (JSON.get &fc
                                                                                                 "args")
                                                                                  (Maybe.Just a)
                                                                                    (llm-json-to-str &a)
                                                                                  _
                                                                                    @"")))))
                                      _
                                        (let [tok (llm-json-str part &[@"text"])
                                              is-thought (match (JSON.get part
                                                                          "thought")
                                                (Maybe.Just v)
                                                  (Maybe.from (JSON.as-bool &v)
                                                              false)
                                                _ false)]
                                          (cond
                                            (and (> (String.length &tok) 0)
                                                 is-thought)
                                              (set! chunks
                                                    (Array.push-back chunks
                                                                     (StreamChunk.ChunkText (String.concat &[(soh-prefix)
                                                                                                             tok]))))
                                            (> (String.length &tok) 0)
                                              (set! chunks
                                                    (Array.push-back chunks
                                                                     (StreamChunk.ChunkText tok)))
                                            ())))))
                                (if (> (Array.length &chunks) 0)
                                  chunks
                                  (if has-finish
                                    [(StreamChunk.ChunkDone)]
                                    [(StreamChunk.ChunkSkip)])))
                            _
                              (if has-finish
                                [(StreamChunk.ChunkDone)]
                                [(StreamChunk.ChunkSkip)]))
                        _
                          (if has-finish
                            [(StreamChunk.ChunkDone)]
                            [(StreamChunk.ChunkSkip)])))
                  _ [(StreamChunk.ChunkSkip)])
              _ [(StreamChunk.ChunkSkip)])
          _ [(StreamChunk.ChunkSkip)]))
      [(StreamChunk.ChunkSkip)])))

(defn llm-known-provider? [name]
  (or (= name "openai")
      (or (= name "anthropic") (or (= name "ollama") (= name "gemini")))))

(defn llm-build-body [provider req]
  (cond
    (= provider "openai") (OpenAI.build-request req)
    (= provider "anthropic") (Anthropic.build-request req)
    (= provider "ollama") (Ollama.build-request req)
    (= provider "gemini") (Gemini.build-request req)
    @""))

(defn llm-build-stream-body [provider req]
  (cond
    (= provider "openai") (OpenAI.build-stream-request req)
    (= provider "anthropic") (Anthropic.build-stream-request req)
    (= provider "ollama") (Ollama.build-stream-request req)
    (= provider "gemini") (Gemini.build-stream-request req)
    @""))

(defn llm-endpoint-path [provider config req]
  (cond
    (= provider "openai") (OpenAI.endpoint config)
    (= provider "anthropic") (Anthropic.endpoint config)
    (= provider "ollama") (Ollama.endpoint config)
    (= provider "gemini") (Gemini.endpoint config (LLMRequest.model req))
    @""))

(defn llm-stream-endpoint-path [provider config req]
  (cond
    (= provider "openai") (OpenAI.endpoint config)
    (= provider "anthropic") (Anthropic.endpoint config)
    (= provider "ollama") (Ollama.endpoint config)
    (= provider "gemini") (Gemini.stream-endpoint config (LLMRequest.model req))
    @""))

(defn llm-build-headers [provider config body-len]
  (cond
    (= provider "openai") (OpenAI.headers config body-len)
    (= provider "anthropic") (Anthropic.headers config body-len)
    (= provider "ollama") (Ollama.headers config body-len)
    (= provider "gemini") (Gemini.headers config body-len)
    (the (Map String (Array String)) {})))

(defn llm-parse-success [provider body]
  (cond
    (= provider "openai") (OpenAI.parse-response body)
    (= provider "anthropic") (Anthropic.parse-response body)
    (= provider "ollama") (Ollama.parse-response body)
    (= provider "gemini") (Gemini.parse-response body)
    (Result.Error @"unknown provider")))

(doc LLM "is a multi-provider LLM client supporting Anthropic, OpenAI, Ollama,
and Gemini.

## Quick start
```
(let [config (LLM.ollama \"http://localhost:11434\")
      req (LLM.chat-request \"llama3\" [(Message.user \"hello\")] 256 0.7)]
  (match (LLM.chat &config &req)
    (Result.Success r) (println* (LLMResponse.content &r))
    (Result.Error e) (IO.errorln &e)))
```")
(defmodule LLM
  (doc anthropic "creates a provider config for the Anthropic API.")
  (defn anthropic [api-key]
    (ProviderConfig.init @"anthropic"
                         @"https://api.anthropic.com"
                         @api-key
                         @"2023-06-01"))

  (doc openai "creates a provider config for the OpenAI API.")
  (defn openai [api-key]
    (ProviderConfig.init @"openai" @"https://api.openai.com" @api-key @""))

  (doc ollama "creates a provider config for Ollama. Takes the base URL
(e.g. `\"http://localhost:11434\"`).")
  (defn ollama [base-url] (ProviderConfig.init @"ollama" @base-url @"" @""))

  (doc vllm "creates a provider config for a vLLM server. Uses the OpenAI
wire format. Takes the base URL (e.g. `\"http://dgx:8000\"`) and an API
key (pass empty string for none).")
  (defn vllm [base-url api-key]
    (ProviderConfig.init @"openai" @base-url @api-key @""))

  (doc gemini "creates a provider config for the Google Gemini API.")
  (defn gemini [api-key]
    (ProviderConfig.init @"gemini"
                         @"https://generativelanguage.googleapis.com"
                         @api-key
                         @""))

  (doc chat-request "creates an LLM request without tools.")
  (defn chat-request [model messages max-tokens temperature]
    (LLMRequest.init @model
                     messages
                     max-tokens
                     temperature
                     []
                     format-text
                     (JSON.Null)
                     -1.0
                     -1
                     -100.0
                     -100.0
                     -1))

  (doc chat-request-with-tools "creates an LLM request with tool definitions.")
  (defn chat-request-with-tools [model messages max-tokens temperature tools]
    (LLMRequest.init @model
                     messages
                     max-tokens
                     temperature
                     tools
                     format-text
                     (JSON.Null)
                     -1.0
                     -1
                     -100.0
                     -100.0
                     -1))

  (doc chat-request-json "creates an LLM request that asks for a JSON response.

Note: Anthropic has no native JSON mode, so this falls back to a system prompt
instruction (best-effort, not guaranteed). All other providers use their native
JSON mode.")
  (defn chat-request-json [model messages max-tokens temperature]
    (LLMRequest.init @model
                     messages
                     max-tokens
                     temperature
                     []
                     format-json
                     (JSON.Null)
                     -1.0
                     -1
                     -100.0
                     -100.0
                     -1))

  (doc chat-request-with-schema "creates an LLM request constrained to a JSON
schema. The schema is a JSON value (use the `JSON` constructors).")
  (defn chat-request-with-schema [model messages max-tokens temperature schema]
    (LLMRequest.init @model
                     messages
                     max-tokens
                     temperature
                     []
                     format-json-schema
                     schema
                     -1.0
                     -1
                     -100.0
                     -100.0
                     -1))

  (doc chat "sends a chat request to the configured provider.
Returns `(Result LLMResponse LLMError)`. On HTTP errors (4xx/5xx), returns a
structured `LLMError.Api` with status code, error type, and message parsed from
the provider's error response. On transport failures, returns `LLMError.Transport`.")
  (defn chat [config req]
    (let [name (ProviderConfig.name config)]
      (if (not (llm-known-provider? name))
        (llm-transport-error (String.concat &[@"unknown provider: " @name]))
        (let [base (ProviderConfig.base-url config)
              body (llm-build-body name req)
              path (llm-endpoint-path name config req)
              url (String.concat &[@base path])
              hdrs (llm-build-headers name config (String.length &body))]
          (match (Client.request "POST" &url hdrs &body)
            (Result.Success resp)
              (if (Response.ok? &resp)
                (match (llm-parse-success name (Response.body &resp))
                  (Result.Success r) (Result.Success r)
                  (Result.Error e) (llm-transport-error e))
                (llm-parse-error name
                                 @(Response.code &resp)
                                 (Response.body &resp)))
            (Result.Error e) (llm-transport-error e)))))))

(doc LlmStream "is a pull-based stream of tokens and tool calls from an LLM
response. Wraps a `ResponseStream` and parses provider-specific streaming
formats. Use `poll` for text-only streaming or `poll-event` for streaming
with tool call support.

```
(match (LLM.chat-stream &config &req)
  (Result.Success stream)
    (do
      (while-do true
        (match (LlmStream.poll-event &stream)
          (Maybe.Nothing) (break)
          (Maybe.Just evt)
            (match-ref &evt
              (StreamEvent.Text tok) (IO.print tok)
              (StreamEvent.ToolCallEvent tc)
                (IO.println &(String.concat
                  &[@\"tool: \" @(ToolCall.name tc)])))))
      (LlmStream.close stream))
  (Result.Error e) (IO.errorln &e))
```")
(deftype LlmStream
  [rs ResponseStream
   linebuf String
   provider String
   tc-id String
   tc-name String
   tc-args String
   pending-tcs (Array ToolCall)
   stream-done Bool])

(defn llm-stream-extract-line [s]
  (let [buf (LlmStream.linebuf s)
        pos (String.index-of buf \newline)]
    (if (< pos 0)
      (Maybe.Nothing)
      (let-do [line (String.byte-slice buf 0 pos)
               rest (String.byte-slice buf (inc pos) (String.length buf))]
        (LlmStream.set-linebuf! s rest)
        (Maybe.Just line)))))

(defn llm-stream-parse-line [provider line]
  (cond
    (= provider "ollama") (Ollama.parse-delta line)
    (= provider "openai") (OpenAI.parse-delta line)
    (= provider "anthropic") (Anthropic.parse-delta line)
    (= provider "gemini") (Gemini.parse-delta line)
    (Maybe.Nothing)))

(defn llm-stream-parse-event [provider line]
  (cond
    (= provider "ollama") (Ollama.parse-stream-event line)
    (= provider "openai") (OpenAI.parse-stream-event line)
    (= provider "anthropic") (Anthropic.parse-stream-event line)
    (= provider "gemini") (Gemini.parse-stream-event line)
    [(StreamChunk.ChunkSkip)]))

(defn llm-finalize-pending-tc [s]
  (when (> (String.length (LlmStream.tc-id s)) 0)
    (let [tc (ToolCall.init @(LlmStream.tc-id s)
                            @(LlmStream.tc-name s)
                            @(LlmStream.tc-args s))]
      (LlmStream.set-pending-tcs! s
                                  (Array.push-back @(LlmStream.pending-tcs s) tc))
      (LlmStream.set-tc-id! s @"")
      (LlmStream.set-tc-name! s @"")
      (LlmStream.set-tc-args! s @""))))

(defn llm-dequeue-pending-tc [s]
  (let-do [tc @(Array.unsafe-nth (LlmStream.pending-tcs s) 0)
           new-pending (the (Array ToolCall) [])]
    (for [i 1 (Array.length (LlmStream.pending-tcs s))]
      (set! new-pending
            (Array.push-back new-pending
                             @(Array.unsafe-nth (LlmStream.pending-tcs s) i))))
    (LlmStream.set-pending-tcs! s new-pending)
    tc))

(defmodule LlmStream
  (doc poll
    "returns the next token from the LLM stream, or `Nothing` when complete.
For text-only streaming. Use `poll-event` for streaming with tool call
support.")
  (defn poll [s]
    (let-do [result (Maybe.Nothing)
             done false]
      (while (and (not done) (Maybe.nothing? &result))
        (match (llm-stream-extract-line s)
          (Maybe.Just line)
            (let [trimmed (String.trim &line)]
              (when (> (String.length &trimmed) 0)
                (match (llm-stream-parse-line (provider s) &trimmed)
                  (Maybe.Just tok) (set! result (Maybe.Just tok))
                  (Maybe.Nothing) ())))
          (Maybe.Nothing)
            (match (ResponseStream.poll (rs s))
              (Maybe.Nothing) (set! done true)
              (Maybe.Just chunk)
                (LlmStream.set-linebuf! s
                                        (String.concat &[@(LlmStream.linebuf s)
                                                         chunk])))))
      result))
  (implements poll LlmStream.poll)

  (doc poll-event "returns the next `StreamEvent` from the LLM stream, or
`Nothing` when complete. Unlike `poll`, this handles tool calls from streaming
responses — incremental tool call data is accumulated internally and emitted
as complete `StreamEvent.ToolCallEvent` values. Parallel tool calls (multiple
tool calls in a single response) are fully supported.

Gemini does not provide tool call IDs, so `ToolCall` values from Gemini
streams will have an empty string as their ID.

```
(while-do true
  (match (LlmStream.poll-event &stream)
    (Maybe.Nothing) (break)
    (Maybe.Just evt)
      (match-ref &evt
        (StreamEvent.Text tok) (IO.print tok)
        (StreamEvent.ToolCallEvent tc)
          (println* \"tool: \" (ToolCall.name tc)))))
```")
  (defn poll-event [s]
    (let-do [result (the (Maybe StreamEvent) (Maybe.Nothing))
             done false]
      (when (> (Array.length (pending-tcs s)) 0)
        (let [tc (llm-dequeue-pending-tc s)]
          (set! result (Maybe.Just (StreamEvent.ToolCallEvent tc)))
          (set! done true)))
      (when (and (not done) @(stream-done s)) (set! done true))
      (while (and (not done) (Maybe.nothing? &result))
        (match (llm-stream-extract-line s)
          (Maybe.Just line)
            (let [trimmed (String.trim &line)]
              (when (> (String.length &trimmed) 0)
                (let [chunks (llm-stream-parse-event (provider s) &trimmed)]
                  (for [ci 0 (Array.length &chunks)]
                    (match-ref (Array.unsafe-nth &chunks ci)
                      (StreamChunk.ChunkText tok)
                        (when (Maybe.nothing? &result)
                          (set! result (Maybe.Just (StreamEvent.Text @tok))))
                      (StreamChunk.ChunkToolStart id name args)
                        (do
                          (llm-finalize-pending-tc s)
                          (LlmStream.set-tc-id! s @id)
                          (LlmStream.set-tc-name! s @name)
                          (LlmStream.set-tc-args! s @args))
                      (StreamChunk.ChunkToolDelta args)
                        (LlmStream.set-tc-args! s
                                                (String.concat &[@(tc-args s)
                                                                 @args]))
                      (StreamChunk.ChunkToolEnd) (llm-finalize-pending-tc s)
                      (StreamChunk.ChunkToolFull tc)
                        (LlmStream.set-pending-tcs! s
                                                    (Array.push-back @(pending-tcs s)
                                                                     @tc))
                      (StreamChunk.ChunkDone)
                        (do
                          (llm-finalize-pending-tc s)
                          (LlmStream.set-stream-done! s true)
                          (when (and (not done) (Maybe.nothing? &result))
                            (if (> (Array.length (pending-tcs s)) 0)
                              (let [tc (llm-dequeue-pending-tc s)]
                                (set! result
                                      (Maybe.Just (StreamEvent.ToolCallEvent tc))))
                              (set! done true))))
                      (StreamChunk.ChunkSkip) ())))))
          (Maybe.Nothing)
            (match (ResponseStream.poll (rs s))
              (Maybe.Nothing)
                (do
                  (llm-finalize-pending-tc s)
                  (if (> (Array.length (pending-tcs s)) 0)
                    (let [tc (llm-dequeue-pending-tc s)]
                      (set! result (Maybe.Just (StreamEvent.ToolCallEvent tc))))
                    (set! done true)))
              (Maybe.Just chunk)
                (LlmStream.set-linebuf! s
                                        (String.concat &[@(LlmStream.linebuf s)
                                                         chunk])))))
      result))

  (doc close "closes the underlying connection.")
  (defn close [s] (ResponseStream.close! (rs &s))))

(defmodule LLM
  (doc chat-stream "sends a streaming chat request and returns an `LlmStream`.
Poll the stream for tokens. Returns `(Result LlmStream LLMError)`. Checks
the HTTP status code before returning the stream.")
  (defn chat-stream [config req]
    (let [name (ProviderConfig.name config)]
      (if (not (llm-known-provider? name))
        (llm-transport-error (String.concat &[@"unknown provider: " @name]))
        (let [base (ProviderConfig.base-url config)
              body (llm-build-stream-body name req)
              path (llm-stream-endpoint-path name config req)
              url (String.concat &[@base path])
              hdrs (llm-build-headers name config (String.length &body))]
          (match (Client.request-stream "POST" &url hdrs &body)
            (Result.Success rs)
              (if (< @(ResponseStream.status-code &rs) 400)
                (Result.Success
                  (LlmStream.init rs @"" @name @"" @"" @"" [] false))
                (let-do [sc @(ResponseStream.status-code &rs)
                         err-body @""
                         drain-done false]
                  (while (not drain-done)
                    (match (ResponseStream.poll &rs)
                      (Maybe.Nothing) (set! drain-done true)
                      (Maybe.Just chunk)
                        (set! err-body (String.concat &[err-body chunk]))))
                  (ResponseStream.close rs)
                  (llm-parse-error name sc &err-body)))
            (Result.Error e) (llm-transport-error e)))))))

(defn llm-loop-should-continue? [response iter max-iters]
  (and (> (Array.length (LLMResponse.tool-calls response)) 0) (< iter max-iters)))

(defn llm-collect-tool-results [tcs handler]
  (let-do [results (the (Array Message) [])]
    (for [j 0 (Array.length tcs)]
      (let [tc (Array.unsafe-nth tcs j)
            res (~handler tc)
            id (if (= (String.length (ToolCall.id tc)) 0)
              @(ToolCall.name tc)
              @(ToolCall.id tc))]
        (set! results (Array.push-back results (Message.tool-result &id &res)))))
    results))

(defn llm-apply-loop-step [msgs response handler]
  (let [asst-msg (Message.from-response response)
        tool-msgs (llm-collect-tool-results (LLMResponse.tool-calls response)
                                            handler)]
    (Array.concat &[(Array.push-back msgs asst-msg) tool-msgs])))

(defmodule LLM
  (doc chat-loop "runs an agentic tool-use loop. Calls `chat` with the given
tools, invokes `handler` for each tool call in the response, appends tool
results to the conversation, and repeats until the model stops calling tools
or `max-iters` iterations are reached.

The handler receives a `(Ref ToolCall)` and returns the tool result as a
`String`.

Returns the final `(Result LLMResponse LLMError)`. If the iteration limit is
reached, the last response is returned (it may still contain tool calls).

```
(let [config (LLM.ollama \"http://localhost:11434\")
      tools [(ToolDef.init @\"get_weather\" @\"Get weather\" schema)]
      msgs [(Message.user \"Weather in Paris?\")]
      handler (fn [tc]
                (if (= (ToolCall.name tc) \"get_weather\")
                  @\"22C, sunny\"
                  @\"unknown tool\"))]
  (match (LLM.chat-loop &config \"llama3\" msgs 256 0.7 &tools handler 10)
    (Result.Success r) (println* (LLMResponse.content &r))
    (Result.Error e) (IO.errorln &(LLMError.str &e))))
```")
  (defn chat-loop [config
                   model
                   messages
                   max-tokens
                   temperature
                   tools
                   handler
                   max-iters]
    (let-do [msgs messages
             result (the (Result LLMResponse LLMError)
                         (Result.Error (LLMError.Transport @"")))
             done false
             i 0]
      (while (not done)
        (let [req (LLM.chat-request-with-tools model
                                               @&msgs
                                               max-tokens
                                               temperature
                                               @tools)]
          (match (LLM.chat config &req)
            (Result.Error e)
              (do (set! result (Result.Error e)) (set! done true))
            (Result.Success r)
              (if (not (llm-loop-should-continue? &r i max-iters))
                (do (set! result (Result.Success r)) (set! done true))
                (do
                  (set! msgs (llm-apply-loop-step msgs &r &handler))
                  (set! i (inc i)))))))
      result)))

(doc EmbeddingRequest "a request to generate text embeddings.

Build with `LLM.embedding-request` rather than constructing directly.

- `model`: the provider-specific embedding model identifier
- `input`: an array of text strings to embed")
(deftype EmbeddingRequest [model String
                           input (Array String)])

(doc EmbeddingResponse "a parsed embeddings response.

- `embeddings`: an array of embedding vectors, one per input text, each a
  dense array of `Double` values
- `total-tokens`: total tokens consumed by the request (0 for providers
  that do not report token usage on embeddings)")
(deftype EmbeddingResponse [embeddings (Array (Array Double))
                            total-tokens Int])

(defn llm-json-doubles [j]
  (match (JSON.as-arr j)
    (Maybe.Just boxes)
      (Array.copy-map
        &(fn [bx] (Maybe.from (JSON.as-num (Box.peek bx)) 0.0))
        &boxes)
    _ (the (Array Double) [])))

(defmodule OpenAI
  (defn build-embedding-request [req]
    (let [input-arr (JSON.Arr
            (Array.copy-map &(fn [s] (Box.init (JSON.Str @s)))
                            (EmbeddingRequest.input req)))
          entries [(JSON.entry @"model" (JSON.Str @(EmbeddingRequest.model req)))
                   (JSON.entry @"input" input-arr)]]
      (llm-json-to-str &(JSON.obj entries))))

  (defn parse-embedding-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [embeddings (match (JSON.get &j "data")
                (Maybe.Just arr)
                  (match (JSON.as-arr &arr)
                    (Maybe.Just boxes)
                      (Array.copy-map
                        &(fn [bx]
                          (match (JSON.get (Box.peek bx) "embedding")
                            (Maybe.Just emb) (llm-json-doubles &emb)
                            _ (the (Array Double) [])))
                        &boxes)
                    _ (the (Array (Array Double)) []))
                _ (the (Array (Array Double)) []))
              total-tokens (llm-json-int &j &[@"usage" @"total_tokens"])]
          (Result.Success (EmbeddingResponse.init embeddings total-tokens)))))

  (defn embedding-endpoint [_config] @"/v1/embeddings"))

(defmodule Ollama
  (defn build-embedding-request [req]
    (let [input-arr (JSON.Arr
            (Array.copy-map &(fn [s] (Box.init (JSON.Str @s)))
                            (EmbeddingRequest.input req)))
          entries [(JSON.entry @"model" (JSON.Str @(EmbeddingRequest.model req)))
                   (JSON.entry @"input" input-arr)]]
      (llm-json-to-str &(JSON.obj entries))))

  (defn parse-embedding-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [embeddings (match (JSON.get &j "embeddings")
                (Maybe.Just arr)
                  (match (JSON.as-arr &arr)
                    (Maybe.Just boxes)
                      (Array.copy-map
                        &(fn [bx] (llm-json-doubles (Box.peek bx)))
                        &boxes)
                    _ (the (Array (Array Double)) []))
                _ (the (Array (Array Double)) []))]
          (Result.Success (EmbeddingResponse.init embeddings 0)))))

  (defn embedding-endpoint [_config] @"/api/embed"))

(defmodule Gemini
  (defn build-embedding-request [req]
    (let [model-path (String.concat &[@"models/" @(EmbeddingRequest.model req)])
          reqs (JSON.Arr
            (Array.copy-map
              &(fn [s]
                (Box.init
                  (JSON.obj
                    [(JSON.entry @"model" (JSON.Str @&model-path))
                     (JSON.entry @"content"
                                 (JSON.obj
                                   [(JSON.entry @"parts"
                                                (JSON.Arr
                                                  [(Box.init
                                                     (JSON.obj [(JSON.entry @"text"
                                                                            (JSON.Str @s))]))]))]))])))
              (EmbeddingRequest.input req)))]
      (llm-json-to-str &(JSON.obj [(JSON.entry @"requests" reqs)]))))

  (defn parse-embedding-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [embeddings (match (JSON.get &j "embeddings")
                (Maybe.Just arr)
                  (match (JSON.as-arr &arr)
                    (Maybe.Just boxes)
                      (Array.copy-map
                        &(fn [bx]
                          (match (JSON.get (Box.peek bx) "values")
                            (Maybe.Just vals) (llm-json-doubles &vals)
                            _ (the (Array Double) [])))
                        &boxes)
                    _ (the (Array (Array Double)) []))
                _ (the (Array (Array Double)) []))]
          (Result.Success (EmbeddingResponse.init embeddings 0)))))

  (defn embedding-endpoint [_config model]
    (String.concat &[@"/v1beta/models/" @model @":batchEmbedContents"])))

(defn llm-embedding-provider? [name]
  (or (= name "openai") (or (= name "ollama") (= name "gemini"))))

(defn llm-build-embedding-body [provider req]
  (cond
    (= provider "openai") (OpenAI.build-embedding-request req)
    (= provider "ollama") (Ollama.build-embedding-request req)
    (= provider "gemini") (Gemini.build-embedding-request req)
    @""))

(defn llm-embedding-endpoint-path [provider config req]
  (cond
    (= provider "openai") (OpenAI.embedding-endpoint config)
    (= provider "ollama") (Ollama.embedding-endpoint config)
    (= provider "gemini")
      (Gemini.embedding-endpoint config (EmbeddingRequest.model req))
    @""))

(defn llm-parse-embedding-success [provider body]
  (cond
    (= provider "openai") (OpenAI.parse-embedding-response body)
    (= provider "ollama") (Ollama.parse-embedding-response body)
    (= provider "gemini") (Gemini.parse-embedding-response body)
    (Result.Error @"unknown provider")))

(defmodule LLM
  (doc embedding-request "creates an embedding request.

- `model`: the provider-specific embedding model identifier
- `input`: an array of text strings to embed")
  (defn embedding-request [model input] (EmbeddingRequest.init @model input))

  (doc embed "sends an embedding request to the configured provider.
Returns `(Result EmbeddingResponse LLMError)`.

Anthropic does not offer an embeddings API; calling this with an Anthropic
config returns a `Transport` error.

```
(let [config (LLM.openai \"sk-...\")
      req (LLM.embedding-request \"text-embedding-3-small\"
            [@\"hello\" @\"world\"])]
  (match (LLM.embed &config &req)
    (Result.Success r)
      (println* (Array.length (EmbeddingResponse.embeddings &r)))
    (Result.Error e) (IO.errorln &(LLMError.str &e))))
```")
  (defn embed [config req]
    (let [name (ProviderConfig.name config)]
      (if (not (llm-embedding-provider? name))
        (llm-transport-error
          (String.concat &[@name @" does not support embeddings"]))
        (let [base (ProviderConfig.base-url config)
              body (llm-build-embedding-body name req)
              path (llm-embedding-endpoint-path name config req)
              url (String.concat &[@base path])
              hdrs (llm-build-headers name config (String.length &body))]
          (match (Client.request "POST" &url hdrs &body)
            (Result.Success resp)
              (if (Response.ok? &resp)
                (match (llm-parse-embedding-success name (Response.body &resp))
                  (Result.Success r) (Result.Success r)
                  (Result.Error e) (llm-transport-error e))
                (llm-parse-error name
                                 @(Response.code &resp)
                                 (Response.body &resp)))
            (Result.Error e) (llm-transport-error e)))))))
