(load "git@github.com:carpentry-org/http-client@0.1.3")
(load "git@github.com:carpentry-org/json@0.2.2")

; ===========================================================================
; Common types
; ===========================================================================

(doc Role "is the role of a chat message. `System` for instructions, `User`
for user input, `Assistant` for model responses, `Tool` for tool result
messages.")
(deftype Role (System []) (User []) (Assistant []) (Tool []))

(doc ToolDef "defines a tool the model can call.

- `name`: the tool name the model uses to invoke it
- `description`: natural-language description the model sees
- `parameters`: a JSON Schema describing the tool's arguments")
(deftype ToolDef [name String description String parameters JSON])

(doc ToolCall "represents a tool invocation from the model.

- `id`: the provider-assigned call ID (used to correlate results back).
  Empty for Gemini, which doesn't use call IDs.
- `name`: the tool name the model is calling
- `arguments`: the JSON-encoded argument object as a string")
(deftype ToolCall [id String name String arguments String])

(doc Message "a single chat message in a conversation.

- `role`: who the message is from
- `content`: the text content
- `tool-calls`: non-empty for assistant messages that invoke tools
- `tool-call-id`: non-empty for tool result messages (role = `Tool`)

Use the constructors in the `Message` module instead of `Message.init`
directly.")
(deftype Message [
  role Role
  content String
  tool-calls (Array ToolCall)
  tool-call-id String
])

; Response format modes for LLMRequest.format-mode
(doc format-text "format-mode for plain text responses (no constraint).")
(def format-text 0)
(doc format-json "format-mode for responses constrained to any valid JSON.")
(def format-json 1)
(doc format-json-schema "format-mode for responses constrained to a JSON schema.")
(def format-json-schema 2)

(doc LLMRequest "a chat request to an LLM provider.

Build with `LLM.chat-request`, `LLM.chat-request-with-tools`,
`LLM.chat-request-json`, or `LLM.chat-request-with-schema` rather than
constructing directly.

- `model`: provider-specific model identifier
- `messages`: the conversation history
- `max-tokens`: maximum output tokens
- `temperature`: sampling temperature (0.0 to 2.0)
- `tools`: tool definitions (empty array if none)
- `format-mode`: `format-text`, `format-json`, or `format-json-schema`
- `format-schema`: JSON schema for structured output (used when mode is
  `format-json-schema`)")
(deftype LLMRequest [
  model String
  messages (Array Message)
  max-tokens Int
  temperature Double
  tools (Array ToolDef)
  format-mode Int
  format-schema JSON
])

(doc LLMResponse "a parsed response from an LLM provider.

- `content`: the text content of the response (may be empty if the model
  called tools instead)
- `stop-reason`: provider-specific reason the generation ended
- `input-tokens`: tokens consumed by the prompt
- `output-tokens`: tokens generated
- `tool-calls`: tool calls the model wants to make (empty if none)")
(deftype LLMResponse [
  content String
  stop-reason String
  input-tokens Int
  output-tokens Int
  tool-calls (Array ToolCall)
])

(doc LLMError "represents an error from an LLM operation.

- `Transport`: connection, DNS, or network error
- `Api`: provider returned an error response (HTTP status, error type, message)")
(deftype LLMError
  (Transport [String])
  (Api [Int String String]))

(defmodule LLMError
  (doc str "formats an `LLMError` as a human-readable string.")
  (defn str [e]
    (match-ref e
      (LLMError.Transport msg) @msg
      (LLMError.Api code typ msg)
        (String.concat &[@"API error " @&(Int.str @code) @" (" @typ @"): " @msg])))
  (implements str LLMError.str)
)

(doc ProviderConfig "configuration for an LLM provider.

Build with `LLM.anthropic`, `LLM.openai`, `LLM.ollama`, or `LLM.gemini`
rather than constructing directly.

- `name`: one of `\"anthropic\"`, `\"openai\"`, `\"ollama\"`, `\"gemini\"`
- `base-url`: the API base URL
- `api-key`: the API key (empty for Ollama)
- `api-version`: used only by Anthropic (e.g. `\"2023-06-01\"`)")
(deftype ProviderConfig [
  name String
  base-url String
  api-key String
  api-version String
])

; ===========================================================================
; JSON helpers
; ===========================================================================

(defmodule Role
  (doc str "returns the wire-format string for a role (`\"system\"`, `\"user\"`,
`\"assistant\"`, or `\"tool\"`).")
  (defn str [r]
    (match-ref r
      (Role.System) @"system"
      (Role.User) @"user"
      (Role.Assistant) @"assistant"
      (Role.Tool) @"tool"))
  (implements str Role.str)
)

(defmodule Message
  (doc user "creates a user message.")
  (defn user [s] (Message.init (Role.User) @s [] @""))

  (doc assistant "creates an assistant message.")
  (defn assistant [s] (Message.init (Role.Assistant) @s [] @""))

  (doc system "creates a system message.")
  (defn system [s] (Message.init (Role.System) @s [] @""))

  (doc tool-result "creates a tool result message for the given tool call ID.")
  (defn tool-result [call-id content]
    (Message.init (Role.Tool) @content [] @call-id))

  (doc from-response "converts an LLMResponse into an assistant message,
preserving any tool calls for conversation history.")
  (defn from-response [r]
    (Message.init (Role.Assistant) @(LLMResponse.content r) @(LLMResponse.tool-calls r) @""))

  (doc to-json "converts a message to a JSON object with role and content keys.
Includes tool_calls for assistant tool call messages, and tool_call_id for
tool result messages.")
  (defn to-json [m]
    (let [base [(JSON.entry @"role" (JSON.Str (Role.str (Message.role m))))
                (JSON.entry @"content" (JSON.Str @(Message.content m)))]
          with-tool-id (if (> (String.length (Message.tool-call-id m)) 0)
                         (Array.push-back base (JSON.entry @"tool_call_id" (JSON.Str @(Message.tool-call-id m))))
                         base)
          with-calls (if (> (Array.length (Message.tool-calls m)) 0)
                       (Array.push-back with-tool-id
                         (JSON.entry @"tool_calls"
                           (JSON.Arr (Array.copy-map
                             &(fn [tc]
                               (let [args-json (match (JSON.parse (ToolCall.arguments tc))
                                                 (Result.Success j) j
                                                 _ (JSON.Str @(ToolCall.arguments tc)))]
                                 (Box.init (JSON.obj [(JSON.entry @"id" (JSON.Str @(ToolCall.id tc)))
                                                      (JSON.entry @"type" (JSON.Str @"function"))
                                                      (JSON.entry @"function"
                                                        (JSON.obj [(JSON.entry @"name" (JSON.Str @(ToolCall.name tc)))
                                                                   (JSON.entry @"arguments" args-json)]))]))))
                             (Message.tool-calls m)))))
                       with-tool-id)]
      (JSON.obj with-calls)))
)

; ===========================================================================
; Internal helpers
; ===========================================================================
; These are top-level (not inside a defmodule) because they're shared across
; the provider modules and Carp's module visibility rules make cross-module
; private helpers awkward. Treat everything prefixed with `llm-` or
; `gemini-` as implementation detail — not part of the public API.

(doc llm-tooldef-to-openai-json "converts a `ToolDef` to OpenAI's function
tool format, which is also what Ollama accepts.")
(defn llm-tooldef-to-openai-json [td]
  (JSON.obj [(JSON.entry @"type" (JSON.Str @"function"))
             (JSON.entry @"function"
               (JSON.obj [(JSON.entry @"name" (JSON.Str @(ToolDef.name td)))
                          (JSON.entry @"description" (JSON.Str @(ToolDef.description td)))
                          (JSON.entry @"parameters" @(ToolDef.parameters td))]))]))

(doc llm-parse-openai-tool-calls "extracts `tool_calls` from an OpenAI or
Ollama response message JSON value, returning an array of `ToolCall`s.")
(defn llm-parse-openai-tool-calls [j]
  (match (JSON.get j "tool_calls")
    (Maybe.Just arr)
      (match (JSON.as-arr &arr)
        (Maybe.Just boxes)
          (Array.copy-map &(fn [bx]
            (let [tc (Box.peek bx)]
              (ToolCall.init
                (llm-json-str tc &[@"id"])
                (llm-json-str tc &[@"function" @"name"])
                (match (JSON.get-in tc &[@"function" @"arguments"])
                  (Maybe.Just args) (llm-json-to-str &args)
                  _ @""))))
            &boxes)
        _ [])
    _ []))

(doc llm-messages-to-json "serializes an array of `Message`s to a `JSON.Arr`
of objects using the OpenAI wire format.")
(defn llm-messages-to-json [msgs]
  (JSON.Arr (Array.copy-map &(fn [m] (Box.init (Message.to-json m))) msgs)))

(doc llm-filter-non-system "returns only the non-system messages from the
given array. Used by providers that send system prompts in a dedicated field.")
(defn llm-filter-non-system [msgs]
  (Array.copy-filter
    &(fn [m] (match-ref (Message.role m)
               (Role.System) false
               _ true))
    msgs))

(doc llm-system-text "joins all system messages in the array into a single
newline-separated string. Returns `(Maybe.Nothing)` if there are no system
messages.")
(defn llm-system-text [msgs]
  (let [sys-msgs (Array.copy-filter
                   &(fn [m] (match-ref (Message.role m)
                              (Role.System) true
                              _ false))
                   msgs)]
    (if (= (Array.length &sys-msgs) 0)
      (Maybe.Nothing)
      (Maybe.Just (String.join "\n" &(Array.copy-map &(fn [m] @(Message.content m)) &sys-msgs))))))

(doc llm-json-to-str "serializes a JSON value to a string. Returns the empty
string on error (which only happens for `NaN` or infinity numeric values).")
(defn llm-json-to-str [j]
  (match (JSON.str j)
    (Result.Success s) s
    (Result.Error _) @""))

(doc llm-json-parse "parses a JSON string, collapsing the specific parse error
type into a plain `String` error for use in our `Result` chains.")
(defn llm-json-parse [s]
  (match (JSON.parse s)
    (Result.Success j) (Result.Success j)
    (Result.Error _) (Result.Error @"JSON parse error")))

(doc llm-transport-error "wraps a message string in an `LLMError.Transport`
result.")
(defn llm-transport-error [msg]
  (Result.Error (LLMError.Transport msg)))

(doc llm-api-error "constructs an `LLMError.Api` result from an HTTP status
code, error type, and message.")
(defn llm-api-error [code typ msg]
  (Result.Error (LLMError.Api code typ msg)))

(doc llm-parse-error-body "parses a provider error response body using the
given JSON key paths to extract the error type and message. Falls back to a
generic error with the raw body on parse failure.")
(defn llm-parse-error-body [code body type-path msg-path]
  (match (llm-json-parse body)
    (Result.Success j)
      (llm-api-error code
        (llm-json-str &j type-path)
        (llm-json-str &j msg-path))
    _ (llm-api-error code @"unknown" @body)))

(doc llm-parse-error "parses a provider-specific error response into an
`LLMError.Api`. Dispatches on the provider name.")
(defn llm-parse-error [provider code body]
  (cond
    (= provider "openai")
      (llm-parse-error-body code body &[@"error" @"type"] &[@"error" @"message"])
    (= provider "anthropic")
      (llm-parse-error-body code body &[@"error" @"type"] &[@"error" @"message"])
    (= provider "ollama")
      ; Ollama errors are just `{"error": "message"}` with no structured type
      (match (llm-json-parse body)
        (Result.Success j) (llm-api-error code @"error" (llm-json-str &j &[@"error"]))
        _ (llm-api-error code @"unknown" @body))
    (= provider "gemini")
      (llm-parse-error-body code body &[@"error" @"status"] &[@"error" @"message"])
    (llm-api-error code @"unknown" @body)))

(doc llm-json-int "extracts an integer from a JSON path. Returns `0` if the
path is missing or the value isn't a number.")
(defn llm-json-int [j keys]
  (match (JSON.get-in j keys)
    (Maybe.Just n) (Double.to-int (Maybe.from (JSON.as-num &n) 0.0))
    _ 0))

(doc llm-json-str "extracts a string from a JSON path. Returns the empty
string if the path is missing or the value isn't a string.")
(defn llm-json-str [j keys]
  (match (JSON.get-in j keys)
    (Maybe.Just v) (Maybe.from (JSON.as-str &v) @"")
    _ @""))

; ===========================================================================
; Provider: OpenAI
; ===========================================================================

(defmodule OpenAI

  (hidden add-format)
  (private add-format)
  (defn add-format [entries req]
    (cond
      (= @(LLMRequest.format-mode req) format-json)
        (Array.push-back entries
          (JSON.entry @"response_format"
            (JSON.obj [(JSON.entry @"type" (JSON.Str @"json_object"))])))
      (= @(LLMRequest.format-mode req) format-json-schema)
        (Array.push-back entries
          (JSON.entry @"response_format"
            (JSON.obj [(JSON.entry @"type" (JSON.Str @"json_schema"))
                       (JSON.entry @"json_schema"
                         (JSON.obj [(JSON.entry @"name" (JSON.Str @"result"))
                                    (JSON.entry @"strict" (JSON.Bool true))
                                    (JSON.entry @"schema" @(LLMRequest.format-schema req))]))])))
      entries))

  (hidden body)
  (private body)
  (defn body [req stream?]
    (let [msgs (llm-messages-to-json (LLMRequest.messages req))
          base [(JSON.entry @"model" (JSON.Str @(LLMRequest.model req)))
                (JSON.entry @"messages" msgs)
                (JSON.entry @"max_tokens" (JSON.Num (Double.from-int @(LLMRequest.max-tokens req))))
                (JSON.entry @"temperature" (JSON.Num @(LLMRequest.temperature req)))]
          with-stream (if stream?
                        (Array.push-back base (JSON.entry @"stream" (JSON.Bool true)))
                        base)
          with-tools (if (and (not stream?) (> (Array.length (LLMRequest.tools req)) 0))
                       (Array.push-back with-stream
                         (JSON.entry @"tools"
                           (JSON.Arr (Array.copy-map &(fn [td] (Box.init (llm-tooldef-to-openai-json td))) (LLMRequest.tools req)))))
                       with-stream)
          entries (OpenAI.add-format with-tools req)]
      (llm-json-to-str &(JSON.obj entries))))

  (doc build-request "builds the JSON request body for the OpenAI chat completions API.")
  (defn build-request [req] (OpenAI.body req false))

  (doc parse-response "parses an OpenAI chat completions response.")
  (defn parse-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [choice (match (JSON.get &j "choices")
                       (Maybe.Just arr) (JSON.nth &arr 0)
                       _ (Maybe.Nothing))
              content (match-ref &choice
                        (Maybe.Just c) (llm-json-str c &[@"message" @"content"])
                        (Maybe.Nothing) @"")
              stop-reason (match-ref &choice
                            (Maybe.Just c) (llm-json-str c &[@"finish_reason"])
                            (Maybe.Nothing) @"")
              tool-calls (match-ref &choice
                           (Maybe.Just c)
                             (match (JSON.get c "message")
                               (Maybe.Just msg) (llm-parse-openai-tool-calls &msg)
                               _ [])
                           (Maybe.Nothing) [])
              input-tokens (llm-json-int &j &[@"usage" @"prompt_tokens"])
              output-tokens (llm-json-int &j &[@"usage" @"completion_tokens"])]
          (Result.Success (LLMResponse.init content stop-reason input-tokens output-tokens tool-calls)))))

  (doc endpoint "returns the chat completions endpoint path.")
  (defn endpoint [_config] @"/v1/chat/completions")

  (doc headers "returns the HTTP headers for an OpenAI request.")
  (defn headers [config body-len]
    (let [auth (String.concat &[@"Bearer " @(ProviderConfig.api-key config)])]
      {@"Content-Type" [@"application/json"]
       @"Authorization" [auth]
       @"Content-Length" [(Int.str body-len)]}))

  (doc build-stream-request "builds a streaming OpenAI chat completions request.")
  (defn build-stream-request [req] (OpenAI.body req true))

  (doc parse-delta "extracts the content delta from a streaming SSE data line.
Falls back to `reasoning_content` when `content` is empty (reasoning models
via vLLM and similar). Thinking tokens are prefixed with a SOH byte (0x01)
so callers can distinguish them from regular content tokens.")
  (defn parse-delta [line]
    (if (String.starts-with? line "data: [DONE]")
      (Maybe.Nothing)
      (if (String.starts-with? line "data: ")
        (let [json-str (String.byte-slice line 6 (String.length line))]
          (match (JSON.parse &json-str)
            (Result.Success j)
              (match (JSON.get &j "choices")
                (Maybe.Just arr)
                  (match (JSON.nth &arr 0)
                    (Maybe.Just choice)
                      (let [tok (llm-json-str &choice &[@"delta" @"content"])]
                        (if (> (String.length &tok) 0)
                          (Maybe.Just tok)
                          (let [think (llm-json-str &choice &[@"delta" @"reasoning"])]
                            (if (> (String.length &think) 0)
                              (Maybe.Just (String.concat &[@"\x01" think]))
                              (Maybe.Nothing)))))
                    _ (Maybe.Nothing))
                _ (Maybe.Nothing))
            _ (Maybe.Nothing)))
        (Maybe.Nothing))))
)

; ===========================================================================
; Provider: Anthropic
; ===========================================================================

(defmodule Anthropic

  (hidden system-text)
  (private system-text)
  (defn system-text [req]
    (let [sys-base (Maybe.from (llm-system-text (LLMRequest.messages req)) @"")
          fmt-instruction (cond
                            (= @(LLMRequest.format-mode req) format-json)
                              @"You must respond with valid JSON only, no other text."
                            (= @(LLMRequest.format-mode req) format-json-schema)
                              (String.concat &[@"You must respond with valid JSON matching this schema, no other text:\n"
                                               (llm-json-to-str (LLMRequest.format-schema req))])
                            @"")]
      (cond
        (= (String.length &fmt-instruction) 0) sys-base
        (= (String.length &sys-base) 0) fmt-instruction
        (String.concat &[sys-base @"\n\n" fmt-instruction]))))

  (hidden body)
  (private body)
  (defn body [req stream?]
    (let [non-system (llm-filter-non-system (LLMRequest.messages req))
          msgs (JSON.Arr (Array.copy-map &(fn [m] (Box.init (Message.to-json m))) &non-system))
          base [(JSON.entry @"model" (JSON.Str @(LLMRequest.model req)))
                (JSON.entry @"messages" msgs)
                (JSON.entry @"max_tokens" (JSON.Num (Double.from-int @(LLMRequest.max-tokens req))))
                (JSON.entry @"temperature" (JSON.Num @(LLMRequest.temperature req)))]
          with-stream (if stream?
                        (Array.push-back base (JSON.entry @"stream" (JSON.Bool true)))
                        base)
          sys-text (Anthropic.system-text req)
          with-sys (if (> (String.length &sys-text) 0)
                     (Array.push-back with-stream (JSON.entry @"system" (JSON.Str sys-text)))
                     with-stream)
          entries (if (and (not stream?) (> (Array.length (LLMRequest.tools req)) 0))
                    (Array.push-back with-sys
                      (JSON.entry @"tools"
                        (JSON.Arr (Array.copy-map
                          &(fn [td] (Box.init (JSON.obj [(JSON.entry @"name" (JSON.Str @(ToolDef.name td)))
                                                         (JSON.entry @"description" (JSON.Str @(ToolDef.description td)))
                                                         (JSON.entry @"input_schema" @(ToolDef.parameters td))])))
                          (LLMRequest.tools req)))))
                    with-sys)]
      (llm-json-to-str &(JSON.obj entries))))

  (doc build-request "builds the JSON request body for the Anthropic messages API.")
  (defn build-request [req] (Anthropic.body req false))

  (doc parse-response "parses an Anthropic messages API response.")
  (defn parse-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [content (match (JSON.get &j "content")
                        (Maybe.Just arr)
                          (match (JSON.nth &arr 0)
                            (Maybe.Just block)
                              (if (= &(llm-json-str &block &[@"type"]) "text")
                                (llm-json-str &block &[@"text"])
                                @"")
                            _ @"")
                        _ @"")
              tool-calls (match (JSON.get &j "content")
                           (Maybe.Just arr)
                             (match (JSON.as-arr &arr)
                               (Maybe.Just boxes)
                                 (let [calls (Array.copy-filter
                                               &(fn [bx] (= &(llm-json-str (Box.peek bx) &[@"type"]) "tool_use"))
                                               &boxes)]
                                   (Array.copy-map &(fn [bx]
                                     (let [tc (Box.peek bx)]
                                       (ToolCall.init
                                         (llm-json-str tc &[@"id"])
                                         (llm-json-str tc &[@"name"])
                                         (match (JSON.get tc "input")
                                           (Maybe.Just inp) (llm-json-to-str &inp)
                                           _ @""))))
                                     &calls))
                               _ [])
                           _ [])
              stop-reason (llm-json-str &j &[@"stop_reason"])
              input-tokens (llm-json-int &j &[@"usage" @"input_tokens"])
              output-tokens (llm-json-int &j &[@"usage" @"output_tokens"])]
          (Result.Success (LLMResponse.init content stop-reason input-tokens output-tokens tool-calls)))))

  (doc endpoint "returns the messages API endpoint path.")
  (defn endpoint [_config] @"/v1/messages")

  (doc headers "returns the HTTP headers for an Anthropic request.")
  (defn headers [config body-len]
    {@"Content-Type" [@"application/json"]
     @"x-api-key" [@(ProviderConfig.api-key config)]
     @"anthropic-version" [@(ProviderConfig.api-version config)]
     @"Content-Length" [(Int.str body-len)]})

  (doc build-stream-request "builds a streaming Anthropic messages request.")
  (defn build-stream-request [req] (Anthropic.body req true))

  (doc parse-delta "extracts text from an Anthropic streaming SSE data line.")
  (defn parse-delta [line]
    (if (String.starts-with? line "data: ")
      (let [json-str (String.byte-slice line 6 (String.length line))]
        (match (JSON.parse &json-str)
          (Result.Success j)
            (match (JSON.get &j "type")
              (Maybe.Just t)
                (if (= &(Maybe.from (JSON.as-str &t) @"") "content_block_delta")
                  (Maybe.Just (llm-json-str &j &[@"delta" @"text"]))
                  (Maybe.Nothing))
              _ (Maybe.Nothing))
          _ (Maybe.Nothing)))
      (Maybe.Nothing)))
)

; ===========================================================================
; Provider: Ollama
; ===========================================================================

(defmodule Ollama

  (hidden body)
  (private body)
  (defn body [req stream?]
    (let [msgs (llm-messages-to-json (LLMRequest.messages req))
          opts (JSON.obj [(JSON.entry @"num_predict" (JSON.Num (Double.from-int @(LLMRequest.max-tokens req))))
                          (JSON.entry @"temperature" (JSON.Num @(LLMRequest.temperature req)))])
          base [(JSON.entry @"model" (JSON.Str @(LLMRequest.model req)))
                (JSON.entry @"messages" msgs)
                (JSON.entry @"stream" (JSON.Bool stream?))
                (JSON.entry @"options" opts)]
          with-tools (if (and (not stream?) (> (Array.length (LLMRequest.tools req)) 0))
                       (Array.push-back base
                         (JSON.entry @"tools"
                           (JSON.Arr (Array.copy-map &(fn [td] (Box.init (llm-tooldef-to-openai-json td))) (LLMRequest.tools req)))))
                       base)
          entries (cond
                    (= @(LLMRequest.format-mode req) format-json)
                      (Array.push-back with-tools (JSON.entry @"format" (JSON.Str @"json")))
                    (= @(LLMRequest.format-mode req) format-json-schema)
                      (Array.push-back with-tools (JSON.entry @"format" @(LLMRequest.format-schema req)))
                    with-tools)]
      (llm-json-to-str &(JSON.obj entries))))

  (doc build-request "builds the JSON request body for the Ollama chat API.")
  (defn build-request [req] (Ollama.body req false))

  (doc parse-response "parses an Ollama chat API response.")
  (defn parse-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [content (llm-json-str &j &[@"message" @"content"])
              tool-calls (match (JSON.get &j "message")
                           (Maybe.Just msg) (llm-parse-openai-tool-calls &msg)
                           _ [])
              stop-reason (llm-json-str &j &[@"done_reason"])
              input-tokens (llm-json-int &j &[@"prompt_eval_count"])
              output-tokens (llm-json-int &j &[@"eval_count"])]
          (Result.Success (LLMResponse.init content stop-reason input-tokens output-tokens tool-calls)))))

  (doc endpoint "returns the chat API endpoint path.")
  (defn endpoint [_config] @"/api/chat")

  (doc headers "returns the HTTP headers for an Ollama request.")
  (defn headers [_config body-len]
    {@"Content-Type" [@"application/json"]
     @"Content-Length" [(Int.str body-len)]})

  (doc build-stream-request "builds a streaming Ollama chat request.")
  (defn build-stream-request [req] (Ollama.body req true))

  (doc parse-delta "extracts content from an Ollama streaming NDJSON line.
Falls back to the `thinking` field when `content` is empty (reasoning models).
Thinking tokens are prefixed with a SOH byte (0x01) so callers can distinguish
them from regular content tokens.")
  (defn parse-delta [line]
    (match (JSON.parse line)
      (Result.Success j)
        (match (JSON.get &j "done")
          (Maybe.Just d)
            (if (Maybe.from (JSON.as-bool &d) false)
              (Maybe.Nothing)
              (let [tok (llm-json-str &j &[@"message" @"content"])]
                (if (> (String.length &tok) 0)
                  (Maybe.Just tok)
                  (let [think (llm-json-str &j &[@"message" @"thinking"])]
                    (if (> (String.length &think) 0)
                      (Maybe.Just (String.concat &[@"\x01" think]))
                      (Maybe.Nothing))))))
          _ (Maybe.Nothing))
      _ (Maybe.Nothing)))
)

; ===========================================================================
; Provider: Gemini
; ===========================================================================

(doc gemini-message-to-json "converts a `Message` to Gemini's `contents`
element format, with a single `text` part wrapping the content.")
(defn gemini-message-to-json [m]
  (JSON.obj [(JSON.entry @"role" (JSON.Str (Role.str (Message.role m))))
             (JSON.entry @"parts" (JSON.Arr [(Box.init
               (JSON.obj [(JSON.entry @"text" (JSON.Str @(Message.content m)))]))]))]))

(defmodule Gemini

  (hidden body)
  (private body)
  (defn body [req include-tools?]
    (let [non-system (the (Array Message) (llm-filter-non-system (LLMRequest.messages req)))
          contents (JSON.Arr (Array.copy-map &(fn [m] (Box.init (gemini-message-to-json m))) &non-system))
          gen-base [(JSON.entry @"maxOutputTokens" (JSON.Num (Double.from-int @(LLMRequest.max-tokens req))))
                    (JSON.entry @"temperature" (JSON.Num @(LLMRequest.temperature req)))]
          gen-with-mime (if (> @(LLMRequest.format-mode req) format-text)
                          (Array.push-back gen-base
                            (JSON.entry @"responseMimeType" (JSON.Str @"application/json")))
                          gen-base)
          gen-entries (if (= @(LLMRequest.format-mode req) format-json-schema)
                        (Array.push-back gen-with-mime
                          (JSON.entry @"responseSchema" @(LLMRequest.format-schema req)))
                        gen-with-mime)
          gen-config (JSON.obj gen-entries)
          base [(JSON.entry @"contents" contents)
                (JSON.entry @"generationConfig" gen-config)]
          with-sys (match (llm-system-text (LLMRequest.messages req))
                     (Maybe.Just sys)
                       (let [si (JSON.obj [(JSON.entry @"parts" (JSON.Arr [(Box.init
                                             (JSON.obj [(JSON.entry @"text" (JSON.Str sys))]))]))])]
                         (Array.push-back base (JSON.entry @"systemInstruction" si)))
                     (Maybe.Nothing) base)
          entries (if (and include-tools? (> (Array.length (LLMRequest.tools req)) 0))
                    (Array.push-back with-sys
                      (JSON.entry @"tools"
                        (JSON.Arr [(Box.init
                          (JSON.obj [(JSON.entry @"functionDeclarations"
                            (JSON.Arr (Array.copy-map
                              &(fn [td] (Box.init (JSON.obj [(JSON.entry @"name" (JSON.Str @(ToolDef.name td)))
                                                             (JSON.entry @"description" (JSON.Str @(ToolDef.description td)))
                                                             (JSON.entry @"parameters" @(ToolDef.parameters td))])))
                              (LLMRequest.tools req))))]))])))
                    with-sys)]
      (llm-json-to-str &(JSON.obj entries))))

  (doc build-request "builds the JSON request body for the Gemini generateContent API.")
  (defn build-request [req] (Gemini.body req true))

  (doc parse-response "parses a Gemini generateContent API response.")
  (defn parse-response [body]
    (match (llm-json-parse body)
      (Result.Error e) (Result.Error e)
      (Result.Success j)
        (let [cand (match (JSON.get &j "candidates")
                     (Maybe.Just arr) (JSON.nth &arr 0)
                     _ (Maybe.Nothing))
              content (match-ref &cand
                        (Maybe.Just c)
                          (match (JSON.get-in c &[@"content" @"parts"])
                            (Maybe.Just parts)
                              (match (JSON.nth &parts 0)
                                (Maybe.Just part) (llm-json-str &part &[@"text"])
                                _ @"")
                            _ @"")
                        (Maybe.Nothing) @"")
              tool-calls (match-ref &cand
                           (Maybe.Just c)
                             (match (JSON.get-in c &[@"content" @"parts"])
                               (Maybe.Just parts)
                                 (match (JSON.as-arr &parts)
                                   (Maybe.Just boxes)
                                     (let [fc-parts (Array.copy-filter
                                                      &(fn [bx] (match (JSON.get (Box.peek bx) "functionCall")
                                                                  (Maybe.Just _) true
                                                                  _ false))
                                                      &boxes)]
                                       (Array.copy-map &(fn [bx]
                                         (let [fc (Box.peek bx)]
                                           (ToolCall.init
                                             @"" ; Gemini doesn't use call IDs
                                             (llm-json-str fc &[@"functionCall" @"name"])
                                             (match (JSON.get-in fc &[@"functionCall" @"args"])
                                               (Maybe.Just args) (llm-json-to-str &args)
                                               _ @""))))
                                         &fc-parts))
                                   _ [])
                               _ [])
                           (Maybe.Nothing) [])
              stop-reason (match-ref &cand
                            (Maybe.Just c) (llm-json-str c &[@"finishReason"])
                            (Maybe.Nothing) @"")
              input-tokens (llm-json-int &j &[@"usageMetadata" @"promptTokenCount"])
              output-tokens (llm-json-int &j &[@"usageMetadata" @"candidatesTokenCount"])]
          (Result.Success (LLMResponse.init content stop-reason input-tokens output-tokens tool-calls)))))

  (doc endpoint "returns the generateContent endpoint path for the given model.")
  (defn endpoint [_config model]
    (String.concat &[@"/v1beta/models/" @model @":generateContent"]))

  (doc stream-endpoint "returns the streamGenerateContent endpoint path for the given model.
The `?alt=sse` parameter enables Server-Sent Events streaming.")
  (defn stream-endpoint [_config model]
    (String.concat &[@"/v1beta/models/" @model @":streamGenerateContent?alt=sse"]))

  (doc headers "returns the HTTP headers for a Gemini request.")
  (defn headers [config body-len]
    {@"Content-Type" [@"application/json"]
     @"x-goog-api-key" [@(ProviderConfig.api-key config)]
     @"Content-Length" [(Int.str body-len)]})

  (doc build-stream-request "builds a streaming Gemini generateContent request.")
  (defn build-stream-request [req] (Gemini.body req false))

  (doc parse-delta "extracts text from a Gemini streaming SSE data line.")
  (defn parse-delta [line]
    (if (String.starts-with? line "data: ")
      (let [json-str (String.byte-slice line 6 (String.length line))]
        (match (JSON.parse &json-str)
          (Result.Success j)
            (match (JSON.get &j "candidates")
              (Maybe.Just arr)
                (match (JSON.nth &arr 0)
                  (Maybe.Just cand)
                    (match (JSON.get-in &cand &[@"content" @"parts"])
                      (Maybe.Just parts)
                        (match (JSON.nth &parts 0)
                          (Maybe.Just part) (Maybe.Just (llm-json-str &part &[@"text"]))
                          _ (Maybe.Nothing))
                      _ (Maybe.Nothing))
                  _ (Maybe.Nothing))
              _ (Maybe.Nothing))
          _ (Maybe.Nothing)))
      (Maybe.Nothing)))
)

; ===========================================================================
; Provider dispatch helpers
; ===========================================================================
; These map a provider name string to the matching per-provider function.

(doc llm-known-provider? "returns `true` if the given name matches one of
the supported providers (`\"openai\"`, `\"anthropic\"`, `\"ollama\"`,
`\"gemini\"`).")
(defn llm-known-provider? [name]
  (or (= name "openai")
      (or (= name "anthropic")
          (or (= name "ollama")
              (= name "gemini")))))

(doc llm-build-body "builds a provider-specific sync request body JSON
string for the given `LLMRequest`.")
(defn llm-build-body [provider req]
  (cond
    (= provider "openai") (OpenAI.build-request req)
    (= provider "anthropic") (Anthropic.build-request req)
    (= provider "ollama") (Ollama.build-request req)
    (= provider "gemini") (Gemini.build-request req)
    @""))

(doc llm-build-stream-body "builds a provider-specific streaming request
body JSON string for the given `LLMRequest`.")
(defn llm-build-stream-body [provider req]
  (cond
    (= provider "openai") (OpenAI.build-stream-request req)
    (= provider "anthropic") (Anthropic.build-stream-request req)
    (= provider "ollama") (Ollama.build-stream-request req)
    (= provider "gemini") (Gemini.build-stream-request req)
    @""))

(doc llm-endpoint-path "returns the sync API path for the given provider
and request. Only Gemini's endpoint is model-dependent.")
(defn llm-endpoint-path [provider config req]
  (cond
    (= provider "openai") (OpenAI.endpoint config)
    (= provider "anthropic") (Anthropic.endpoint config)
    (= provider "ollama") (Ollama.endpoint config)
    (= provider "gemini") (Gemini.endpoint config (LLMRequest.model req))
    @""))

(doc llm-stream-endpoint-path "returns the streaming API path for the given
provider. For most providers this is the same as the sync endpoint; Gemini
uses a dedicated `:streamGenerateContent?alt=sse` path.")
(defn llm-stream-endpoint-path [provider config req]
  (cond
    (= provider "openai") (OpenAI.endpoint config)
    (= provider "anthropic") (Anthropic.endpoint config)
    (= provider "ollama") (Ollama.endpoint config)
    (= provider "gemini") (Gemini.stream-endpoint config (LLMRequest.model req))
    @""))

(doc llm-build-headers "builds the provider-specific HTTP headers for a
request of the given body length.")
(defn llm-build-headers [provider config body-len]
  (cond
    (= provider "openai") (OpenAI.headers config body-len)
    (= provider "anthropic") (Anthropic.headers config body-len)
    (= provider "ollama") (Ollama.headers config body-len)
    (= provider "gemini") (Gemini.headers config body-len)
    (the (Map String (Array String)) {})))

(doc llm-parse-success "parses a 2xx response body into an `LLMResponse`
using the provider's parser.")
(defn llm-parse-success [provider body]
  (cond
    (= provider "openai") (OpenAI.parse-response body)
    (= provider "anthropic") (Anthropic.parse-response body)
    (= provider "ollama") (Ollama.parse-response body)
    (= provider "gemini") (Gemini.parse-response body)
    (Result.Error @"unknown provider")))

; ===========================================================================
; Main dispatch
; ===========================================================================

(doc LLM "is a multi-provider LLM client supporting Anthropic, OpenAI, Ollama,
and Gemini.

## Quick start
```
(let [config (LLM.ollama \"http://localhost:11434\")
      req (LLM.chat-request \"llama3\" [(Message.user \"hello\")] 256 0.7)]
  (match (LLM.chat &config &req)
    (Result.Success r) (println* (LLMResponse.content &r))
    (Result.Error e) (IO.errorln &e)))
```")
(defmodule LLM

  (doc anthropic "creates a provider config for the Anthropic API.")
  (defn anthropic [api-key]
    (ProviderConfig.init @"anthropic" @"https://api.anthropic.com" @api-key @"2023-06-01"))

  (doc openai "creates a provider config for the OpenAI API.")
  (defn openai [api-key]
    (ProviderConfig.init @"openai" @"https://api.openai.com" @api-key @""))

  (doc ollama "creates a provider config for Ollama. Takes the base URL
(e.g. `\"http://localhost:11434\"`).")
  (defn ollama [base-url]
    (ProviderConfig.init @"ollama" @base-url @"" @""))

  (doc vllm "creates a provider config for a vLLM server. Uses the OpenAI
wire format. Takes the base URL (e.g. `\"http://dgx:8000\"`) and an API
key (pass empty string for none).")
  (defn vllm [base-url api-key]
    (ProviderConfig.init @"openai" @base-url @api-key @""))

  (doc gemini "creates a provider config for the Google Gemini API.")
  (defn gemini [api-key]
    (ProviderConfig.init @"gemini" @"https://generativelanguage.googleapis.com" @api-key @""))

  (doc chat-request "creates an LLM request without tools.")
  (defn chat-request [model messages max-tokens temperature]
    (LLMRequest.init @model messages max-tokens temperature [] format-text (JSON.Null)))

  (doc chat-request-with-tools "creates an LLM request with tool definitions.")
  (defn chat-request-with-tools [model messages max-tokens temperature tools]
    (LLMRequest.init @model messages max-tokens temperature tools format-text (JSON.Null)))

  (doc chat-request-json "creates an LLM request that asks for a JSON response.

Note: Anthropic has no native JSON mode, so this falls back to a system prompt
instruction (best-effort, not guaranteed). All other providers use their native
JSON mode.")
  (defn chat-request-json [model messages max-tokens temperature]
    (LLMRequest.init @model messages max-tokens temperature [] format-json (JSON.Null)))

  (doc chat-request-with-schema "creates an LLM request constrained to a JSON
schema. The schema is a JSON value (use the `JSON` constructors).")
  (defn chat-request-with-schema [model messages max-tokens temperature schema]
    (LLMRequest.init @model messages max-tokens temperature [] format-json-schema schema))

  (doc chat "sends a chat request to the configured provider.
Returns `(Result LLMResponse LLMError)`. On HTTP errors (4xx/5xx), returns a
structured `LLMError.Api` with status code, error type, and message parsed from
the provider's error response. On transport failures, returns `LLMError.Transport`.")
  (defn chat [config req]
    (let [name (ProviderConfig.name config)]
      (if (not (llm-known-provider? name))
        (llm-transport-error (String.concat &[@"unknown provider: " @name]))
        (let [base (ProviderConfig.base-url config)
              body (llm-build-body name req)
              path (llm-endpoint-path name config req)
              url (String.concat &[@base path])
              hdrs (llm-build-headers name config (String.length &body))]
          (match (Client.request "POST" &url hdrs &body)
            (Result.Success resp)
              (if (Response.ok? &resp)
                (match (llm-parse-success name (Response.body &resp))
                  (Result.Success r) (Result.Success r)
                  (Result.Error e) (llm-transport-error e))
                (llm-parse-error name @(Response.code &resp) (Response.body &resp)))
            (Result.Error e) (llm-transport-error e))))))
)

; ===========================================================================
; LlmStream — pull-based token stream
; ===========================================================================

(doc LlmStream "is a pull-based stream of tokens from an LLM response.
Wraps a `ResponseStream` and parses provider-specific streaming formats.
Implements the `poll` interface.

```
(match (LLM.chat-stream &config &req)
  (Result.Success stream)
    (do
      (while-do true
        (match (LlmStream.poll &stream)
          (Maybe.Nothing) (break)
          (Maybe.Just tok) (IO.print &tok)))
      (IO.println \"\")
      (LlmStream.close stream))
  (Result.Error e) (IO.errorln &e))
```")
(deftype LlmStream [
  rs ResponseStream
  linebuf String
  provider String
])

(doc llm-stream-extract-line "extracts a single newline-terminated line from
an `LlmStream`'s line buffer, advancing the buffer. Returns
`(Maybe.Nothing)` if the buffer does not yet contain a full line.")
(defn llm-stream-extract-line [s]
  (let [buf (LlmStream.linebuf s)
        pos (String.index-of buf \newline)]
    (if (< pos 0)
      (Maybe.Nothing)
      (let [line (String.byte-slice buf 0 pos)
            rest (String.byte-slice buf (inc pos) (String.length buf))]
        (do
          (LlmStream.set-linebuf! s rest)
          (Maybe.Just line))))))

(doc llm-stream-parse-line "dispatches a single streaming response line to
the provider-specific `parse-delta` function. Returns `(Maybe.Just token)`
if the line contains a text delta, `(Maybe.Nothing)` otherwise.")
(defn llm-stream-parse-line [provider line]
  (cond
    (= provider "ollama") (Ollama.parse-delta line)
    (= provider "openai") (OpenAI.parse-delta line)
    (= provider "anthropic") (Anthropic.parse-delta line)
    (= provider "gemini") (Gemini.parse-delta line)
    (Maybe.Nothing)))

(defmodule LlmStream

  (doc poll "returns the next token from the LLM stream, or `Nothing` when complete.")
  (defn poll [s]
    (let-do [result (Maybe.Nothing)
             done false]
      (while (and (not done) (Maybe.nothing? &result))
        ; try to get a line from buffer
        (match (llm-stream-extract-line s)
          (Maybe.Just line)
            (let [trimmed (String.trim &line)]
              (when (> (String.length &trimmed) 0)
                (match (llm-stream-parse-line (provider s) &trimmed)
                  (Maybe.Just tok) (set! result (Maybe.Just tok))
                  (Maybe.Nothing) ())))
          (Maybe.Nothing)
            ; need more data from ResponseStream
            (match (ResponseStream.poll (rs s))
              (Maybe.Nothing) (set! done true)
              (Maybe.Just chunk)
                (LlmStream.set-linebuf! s
                  (String.concat &[@(LlmStream.linebuf s) chunk])))))
      result))
  (implements poll LlmStream.poll)

  (doc close "closes the underlying connection.")
  (defn close [s]
    (ResponseStream.close! (rs &s)))
)

; Extend LLM module with streaming

(defmodule LLM

  (doc chat-stream "sends a streaming chat request and returns an `LlmStream`.
Poll the stream for tokens. Returns `(Result LlmStream LLMError)`. Checks
the HTTP status code before returning the stream.")
  (defn chat-stream [config req]
    (let [name (ProviderConfig.name config)]
      (if (not (llm-known-provider? name))
        (llm-transport-error (String.concat &[@"unknown provider: " @name]))
        (let [base (ProviderConfig.base-url config)
              body (llm-build-stream-body name req)
              path (llm-stream-endpoint-path name config req)
              url (String.concat &[@base path])
              hdrs (llm-build-headers name config (String.length &body))]
          (match (Client.request-stream "POST" &url hdrs &body)
            (Result.Success rs)
              (if (< @(ResponseStream.status-code &rs) 400)
                (Result.Success (LlmStream.init rs @"" @name))
                (let [sc @(ResponseStream.status-code &rs)]
                  (do (ResponseStream.close rs)
                      (llm-api-error sc @"stream_error" @""))))
            (Result.Error e) (llm-transport-error e))))))
)
