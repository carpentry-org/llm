            (=
              (Array.length
                (Array.unsafe-nth (EmbeddingResponse.embeddings &r) 0))
              2))
        _ false))
    "Gemini.parse-embedding-response extracts embedding values")

  (assert-true test
    (let [j (JSON.Arr [(Box.init (JSON.Num 1.0)) (Box.init (JSON.Num 2.5))])
