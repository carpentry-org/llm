(load "Test.carp")
(load "../llm.carp")

(use Test)

; ===========================================================================
; JSON serialization tests (no network, no API keys needed)
; ===========================================================================

(deftest test
  ; =========================================================================
  ; Message construction
  ; =========================================================================

  (assert-equal test
    "user"
    &(Role.str (Message.role &(Message.user "hi")))
    "Message.user sets role to user")

  (assert-equal test
    "hi"
    (Message.content &(Message.user "hi"))
    "Message.user preserves content")

  (assert-equal test
    "system"
    &(Role.str (Message.role &(Message.system "be helpful")))
    "Message.system sets role to system")

  ; =========================================================================
  ; Message to-json
  ; =========================================================================

  (assert-true test
    (let [j (Message.to-json &(Message.user "hello"))]
      (and
        (match (JSON.get &j "role")
          (Maybe.Just r) (= &(Maybe.from (JSON.as-str &r) @"") "user")
          _ false)
        (match (JSON.get &j "content")
          (Maybe.Just c) (= &(Maybe.from (JSON.as-str &c) @"") "hello")
          _ false)))
    "Message.to-json produces correct JSON object")

  ; =========================================================================
  ; OpenAI request serialization
  ; =========================================================================

  (assert-true test
    (let [req (LLM.chat-request "gpt-4" [(Message.user "hi")] 100 0.5)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (and
            (= &(llm-json-str &j &[@"model"]) "gpt-4")
            (match (JSON.get &j "messages")
              (Maybe.Just arr)
                (match (JSON.nth &arr 0)
                  (Maybe.Just msg) (= &(llm-json-str &msg &[@"role"]) "user")
                  _ false)
              _ false))
        _ false))
    "OpenAI.build-request produces valid JSON with model and messages")

  ; =========================================================================
  ; OpenAI response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"choices\":[{\"message\":{\"content\":\"hi there\"},\"finish_reason\":\"stop\"}],\"usage\":{\"prompt_tokens\":5,\"completion_tokens\":3}}"]
      (match (OpenAI.parse-response body)
        (Result.Success r)
          (and (= (LLMResponse.content &r) "hi there")
               (and (= (LLMResponse.stop-reason &r) "stop")
                    (and (= @(LLMResponse.input-tokens &r) 5)
                         (= @(LLMResponse.output-tokens &r) 3))))
        _ false))
    "OpenAI.parse-response extracts content, stop reason, and token counts")

  ; =========================================================================
  ; Anthropic request serialization
  ; =========================================================================

  (assert-true test
    (let [req (LLM.chat-request "claude-sonnet-4-20250514"
                                [(Message.system "be nice") (Message.user "hi")]
                                200
                                0.7)
          body (Anthropic.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (and
            (= &(llm-json-str &j &[@"model"]) "claude-sonnet-4-20250514")
            (and
              (= &(llm-json-str &j &[@"system"]) "be nice")
              (match (JSON.get &j "messages")
                (Maybe.Just arr)
                  (match (JSON.nth &arr 0)
                    (Maybe.Just msg) (= &(llm-json-str &msg &[@"role"]) "user")
                    _ false)
                _ false)))
        _ false))
    "Anthropic.build-request separates system message and filters it from messages")

  ; =========================================================================
  ; Anthropic response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"content\":[{\"type\":\"text\",\"text\":\"hello!\"}],\"stop_reason\":\"end_turn\",\"usage\":{\"input_tokens\":10,\"output_tokens\":2}}"]
      (match (Anthropic.parse-response body)
        (Result.Success r)
          (and (= (LLMResponse.content &r) "hello!")
               (= (LLMResponse.stop-reason &r) "end_turn"))
        _ false))
    "Anthropic.parse-response extracts text content block")

  ; =========================================================================
  ; Ollama request serialization
  ; =========================================================================

  (assert-true test
    (let [req (LLM.chat-request "llama3" [(Message.user "hey")] 128 0.8)
          body (Ollama.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (and
            (= &(llm-json-str &j &[@"model"]) "llama3")
            (match (JSON.get &j "stream")
              (Maybe.Just s) (not (Maybe.from (JSON.as-bool &s) true))
              _ false))
        _ false))
    "Ollama.build-request sets model and stream=false")

  ; =========================================================================
  ; Ollama response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"message\":{\"role\":\"assistant\",\"content\":\"yo\"},\"done_reason\":\"stop\",\"prompt_eval_count\":4,\"eval_count\":1}"]
      (match (Ollama.parse-response body)
        (Result.Success r)
          (and (= (LLMResponse.content &r) "yo")
               (= @(LLMResponse.output-tokens &r) 1))
        _ false))
    "Ollama.parse-response extracts message content and eval count")

  ; =========================================================================
  ; Gemini request serialization
  ; =========================================================================

  (assert-true test
    (let [req (LLM.chat-request "gemini-pro" [(Message.user "hi")] 100 0.5)
          body (Gemini.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "contents")
            (Maybe.Just arr) (JSON.arr? &arr)
            _ false)
        _ false))
    "Gemini.build-request produces contents array")

  ; =========================================================================
  ; Gemini response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"candidates\":[{\"content\":{\"parts\":[{\"text\":\"hey\"}]},\"finishReason\":\"STOP\"}],\"usageMetadata\":{\"promptTokenCount\":3,\"candidatesTokenCount\":1}}"]
      (match (Gemini.parse-response body)
        (Result.Success r)
          (and (= (LLMResponse.content &r) "hey")
               (= (LLMResponse.stop-reason &r) "STOP"))
        _ false))
    "Gemini.parse-response extracts candidate text and finish reason")

  ; =========================================================================
  ; Provider config constructors
  ; =========================================================================

  (assert-equal test
    "anthropic"
    (ProviderConfig.name &(LLM.anthropic "sk-test"))
    "LLM.anthropic sets provider name")

  (assert-equal test
    "ollama"
    (ProviderConfig.name &(LLM.ollama "http://localhost:11434"))
    "LLM.ollama sets provider name")

  (assert-equal test
    "http://localhost:11434"
    (ProviderConfig.base-url &(LLM.ollama "http://localhost:11434"))
    "LLM.ollama preserves base URL")

  ; =========================================================================
  ; Unknown provider error
  ; =========================================================================

  (assert-true test
    (let [config (ProviderConfig.init @"bogus" @"http://x" @"" @"")
          req (LLM.chat-request "m" [(Message.user "hi")] 10 0.5)]
      (match (LLM.chat &config &req)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.chat returns Transport error for unknown provider")

  ; =========================================================================
  ; Structured error types
  ; =========================================================================

  (assert-true test
    (let [err (LLMError.Transport @"connection refused")]
      (= &(LLMError.str &err) "connection refused"))
    "LLMError.Transport str shows message")

  (assert-true test
    (let [err (LLMError.Api 401 @"authentication_error" @"invalid api key")]
      (String.contains-string? &(LLMError.str &err) "401"))
    "LLMError.Api str includes status code")

  (assert-true test
    (let [err (LLMError.Api 429 @"rate_limit" @"too many requests")]
      (String.contains-string? &(LLMError.str &err) "too many requests"))
    "LLMError.Api str includes message")

  ; =========================================================================
  ; Error parsing
  ; =========================================================================

  (assert-true test
    (match (the (Result LLMResponse LLMError)
                (llm-parse-error "openai"
                                 401
                                 "{\"error\":{\"type\":\"auth_error\",\"message\":\"bad key\"}}"))
      (Result.Error err)
        (match err
          (LLMError.Api code typ msg) (and (= code 401) (= &typ "auth_error"))
          _ false)
      _ false)
    "OpenAI error parsing extracts type and code")

  (assert-true test
    (match (the (Result LLMResponse LLMError)
                (llm-parse-error "anthropic"
                                 400
                                 "{\"type\":\"error\",\"error\":{\"type\":\"invalid_request\",\"message\":\"bad param\"}}"))
      (Result.Error err)
        (match err
          (LLMError.Api code typ msg) (and (= code 400) (= &msg "bad param"))
          _ false)
      _ false)
    "Anthropic error parsing extracts message")

  (assert-true test
    (match (the (Result LLMResponse LLMError)
                (llm-parse-error "ollama" 404 "{\"error\":\"model not found\"}"))
      (Result.Error err)
        (match err
          (LLMError.Api code _typ msg)
            (and (= code 404) (= &msg "model not found"))
          _ false)
      _ false)
    "Ollama error parsing extracts error string")

  (assert-true test
    (match (the (Result LLMResponse LLMError)
                (llm-parse-error "gemini"
                                 403
                                 "{\"error\":{\"code\":403,\"status\":\"PERMISSION_DENIED\",\"message\":\"no access\"}}"))
      (Result.Error err)
        (match err
          (LLMError.Api code typ msg)
            (and (= code 403) (= &typ "PERMISSION_DENIED"))
          _ false)
      _ false)
    "Gemini error parsing extracts status and code")

  ; =========================================================================
  ; Tool use types
  ; =========================================================================

  (assert-true test
    (let [td (ToolDef.init @"get_weather"
                           @"Get weather"
                           (JSON.obj [(JSON.entry @"type" (JSON.Str @"object"))]))
          j (llm-tooldef-to-openai-json &td)]
      (and
        (= &(llm-json-str &j &[@"type"]) "function")
        (= &(llm-json-str &j &[@"function" @"name"]) "get_weather")))
    "ToolDef serializes to OpenAI function format")

  (assert-equal test
    "tc1"
    (ToolCall.id &(ToolCall.init @"tc1" @"func" @"{}"))
    "ToolCall preserves id")

  (assert-equal test
    "tool"
    &(Role.str (Message.role &(Message.tool-result "tc1" "result")))
    "Message.tool-result has Tool role")

  (assert-equal test
    "tc1"
    (Message.tool-call-id &(Message.tool-result "tc1" "result"))
    "Message.tool-result preserves tool-call-id")

  ; =========================================================================
  ; Tool calls in OpenAI response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"choices\":[{\"message\":{\"content\":\"\",\"tool_calls\":[{\"id\":\"tc1\",\"type\":\"function\",\"function\":{\"name\":\"get_weather\",\"arguments\":\"{\\\"city\\\":\\\"Paris\\\"}\"}}]},\"finish_reason\":\"tool_calls\"}],\"usage\":{\"prompt_tokens\":10,\"completion_tokens\":5}}"]
      (match (OpenAI.parse-response body)
        (Result.Success r)
          (and
            (= (Array.length (LLMResponse.tool-calls &r)) 1)
            (=
              (ToolCall.name (Array.unsafe-nth (LLMResponse.tool-calls &r) 0))
              "get_weather"))
        _ false))
    "OpenAI parse-response extracts tool calls")

  ; =========================================================================
  ; Tool calls in Ollama response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"message\":{\"role\":\"assistant\",\"content\":\"\",\"tool_calls\":[{\"id\":\"call_1\",\"function\":{\"name\":\"get_weather\",\"arguments\":{\"city\":\"Paris\"}}}]},\"done\":true,\"done_reason\":\"stop\",\"prompt_eval_count\":5,\"eval_count\":3}"]
      (match (Ollama.parse-response body)
        (Result.Success r)
          (and
            (= (Array.length (LLMResponse.tool-calls &r)) 1)
            (=
              (ToolCall.name (Array.unsafe-nth (LLMResponse.tool-calls &r) 0))
              "get_weather"))
        _ false))
    "Ollama parse-response extracts tool calls")

  ; =========================================================================
  ; Message.from-response preserves tool calls
  ; =========================================================================

  (assert-true test
    (let [r (LLMResponse.init @""
                              @"tool_calls"
                              5
                              3
                              [(ToolCall.init @"tc1" @"func" @"{}")])]
      (= (Array.length (Message.tool-calls &(Message.from-response &r))) 1))
    "Message.from-response preserves tool calls for conversation history")

  ; =========================================================================
  ; Request with tools includes tools array
  ; =========================================================================

  (assert-true test
    (let [tools [(ToolDef.init @"f" @"desc" (JSON.obj []))]
          req (LLM.chat-request-with-tools "gpt-4"
                                           [(Message.user "hi")]
                                           100
                                           0.5
                                           tools)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "tools") (Maybe.Just arr) (JSON.arr? &arr) _ false)
        _ false))
    "OpenAI build-request includes tools when provided")

  (assert-true test
    (let [req (LLM.chat-request "gpt-4" [(Message.user "hi")] 100 0.5)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "tools") (Maybe.Just _) false (Maybe.Nothing) true)
        _ false))
    "OpenAI build-request omits tools when empty")

  ; =========================================================================
  ; Structured output: OpenAI
  ; =========================================================================

  (assert-true test
    (let [req (LLM.chat-request "gpt-4" [(Message.user "hi")] 100 0.5)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "response_format")
            (Maybe.Just _) false
            (Maybe.Nothing) true)
        _ false))
    "OpenAI build-request omits response_format for Text")

  (assert-true test
    (let [req (LLM.chat-request-json "gpt-4" [(Message.user "hi")] 100 0.5)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (= &(llm-json-str &j &[@"response_format" @"type"]) "json_object")
        _ false))
    "OpenAI build-request sets response_format json_object for Json")

  ; =========================================================================
  ; Structured output: Ollama
  ; =========================================================================

  (assert-true test
    (let [req (LLM.chat-request-json "llama3" [(Message.user "hi")] 100 0.5)
          body (Ollama.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j) (= &(llm-json-str &j &[@"format"]) "json")
        _ false))
    "Ollama build-request sets format=json for Json")

  (assert-true test
    (let [req (LLM.chat-request "llama3" [(Message.user "hi")] 100 0.5)
          body (Ollama.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "format")
            (Maybe.Just _) false
            (Maybe.Nothing) true)
        _ false))
    "Ollama build-request omits format for Text")

  ; =========================================================================
  ; Structured output: Anthropic (system prompt fallback)
  ; =========================================================================

  (assert-true test
    (let [req (LLM.chat-request-json "claude-sonnet-4-20250514"
                                     [(Message.user "hi")]
                                     100
                                     0.5)
          body (Anthropic.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (String.contains-string? &(llm-json-str &j &[@"system"]) "JSON")
        _ false))
    "Anthropic build-request adds JSON instruction to system prompt for Json")

  (assert-true test
    (let [req (LLM.chat-request-json "claude-sonnet-4-20250514"
                                     [(Message.system "be helpful")
                                      (Message.user "hi")]
                                     100
                                     0.5)
          body (Anthropic.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (let [sys (llm-json-str &j &[@"system"])]
            (and
              (String.contains-string? &sys "be helpful")
              (String.contains-string? &sys "JSON")))
        _ false))
    "Anthropic combines existing system msg with JSON instruction")

  ; =========================================================================
  ; Structured output: Gemini
  ; =========================================================================

  (assert-true test
    (let [req (LLM.chat-request-json "gemini-pro" [(Message.user "hi")] 100 0.5)
          body (Gemini.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (=
            &(llm-json-str &j &[@"generationConfig" @"responseMimeType"])
            "application/json")
        _ false))
    "Gemini build-request sets responseMimeType for Json")

  ; =========================================================================
  ; JSON schema mode
  ; =========================================================================

  (assert-true test
    (let [schema (JSON.obj
            [(JSON.entry @"type" (JSON.Str @"object"))
             (JSON.entry @"properties"
                         (JSON.obj
                           [(JSON.entry @"name"
                                        (JSON.obj
                                          [(JSON.entry @"type"
                                                       (JSON.Str @"string"))]))]))])
          req (LLM.chat-request-with-schema "gpt-4"
                                            [(Message.user "hi")]
                                            100
                                            0.5
                                            schema)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (= &(llm-json-str &j &[@"response_format" @"type"]) "json_schema")
        _ false))
    "OpenAI build-request emits json_schema response_format")

  (assert-true test
    (let [schema (JSON.obj [(JSON.entry @"type" (JSON.Str @"object"))])
          req (LLM.chat-request-with-schema "llama3"
                                            [(Message.user "hi")]
                                            100
                                            0.5
                                            schema)
          body (Ollama.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "format") (Maybe.Just f) (JSON.obj? &f) _ false)
        _ false))
    "Ollama build-request passes raw schema as format")

  (assert-true test
    (let [schema (JSON.obj [(JSON.entry @"type" (JSON.Str @"object"))])
          req (LLM.chat-request-with-schema "gemini-pro"
                                            [(Message.user "hi")]
                                            100
                                            0.5
                                            schema)
          body (Gemini.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get-in &j &[@"generationConfig" @"responseSchema"])
            (Maybe.Just _) true
            _ false)
        _ false))
    "Gemini build-request includes responseSchema")

  (assert-true test
    (let [schema (JSON.obj [(JSON.entry @"type" (JSON.Str @"object"))])
          req (LLM.chat-request-with-schema "claude-sonnet-4-20250514"
                                            [(Message.user "hi")]
                                            100
                                            0.5
                                            schema)
          body (Anthropic.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (let [sys (llm-json-str &j &[@"system"])]
            (and (String.contains-string? &sys "JSON")
                 (String.contains-string? &sys "schema")))
        _ false))
    "Anthropic schema mode adds schema to system prompt")

  ; =========================================================================
  ; Transport error on connection failure
  ; =========================================================================

  (assert-true test
    (let [config (ProviderConfig.init @"ollama" @"http://localhost:1" @"" @"")
          req (LLM.chat-request "m" [(Message.user "hi")] 10 0.5)]
      (match (LLM.chat &config &req)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.chat returns Transport error on connection failure")

  ; =========================================================================
  ; ImageContent and Message.user-with-image
  ; =========================================================================

  (assert-equal test
    "user"
    &(Role.str
      (Message.role
        &(Message.user-with-image "describe"
                                  [(ImageContent.init @"image/png" @"abc123")])))
    "Message.user-with-image sets role to user")

  (assert-equal test
    "describe"
    (Message.content
      &(Message.user-with-image "describe"
                                [(ImageContent.init @"image/png" @"abc123")]))
    "Message.user-with-image preserves text content")

  (assert-equal test
    1
    (Array.length
      (Message.images
        &(Message.user-with-image "describe"
                                  [(ImageContent.init @"image/png" @"abc123")])))
    "Message.user-with-image preserves images")

  (assert-equal test
    0
    (Array.length (Message.images &(Message.user "no images")))
    "Message.user has empty images")

  ; =========================================================================
  ; OpenAI image serialization
  ; =========================================================================

  (assert-true test
    (let [msg (Message.user-with-image "what is this?"
                                       [(ImageContent.init @"image/png" @"AAAA")])
          req (LLM.chat-request "gpt-4o" [msg] 100 0.5)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "messages")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just m)
                  (match (JSON.get &m "content")
                    (Maybe.Just content)
                      (and (JSON.arr? &content)
                           (match (JSON.nth &content 0)
                             (Maybe.Just part)
                               (= &(llm-json-str &part &[@"type"]) "text")
                             _ false))
                    _ false)
                _ false)
            _ false)
        _ false))
    "OpenAI serializes image message with content array")

  (assert-true test
    (let [msg (Message.user-with-image "look"
                                       [(ImageContent.init @"image/jpeg" @"DATA")])
          req (LLM.chat-request "gpt-4o" [msg] 100 0.5)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "messages")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just m)
                  (match (JSON.get &m "content")
                    (Maybe.Just content)
                      (match (JSON.nth &content 1)
                        (Maybe.Just img-part)
                          (and
                            (= &(llm-json-str &img-part &[@"type"]) "image_url")
                            (String.contains-string?
                              &(llm-json-str &img-part &[@"image_url" @"url"])
                              "data:image/jpeg;base64,DATA"))
                        _ false)
                    _ false)
                _ false)
            _ false)
        _ false))
    "OpenAI image part has image_url type with data URI")

  (assert-true test
    (let [msg (Message.user "no images")
          j (Message.to-json &msg)]
      (match (JSON.get &j "content") (Maybe.Just c) (JSON.str? &c) _ false))
    "Message.to-json keeps content as string when no images")

  ; =========================================================================
  ; Anthropic image serialization
  ; =========================================================================

  (assert-true test
    (let [msg (Message.user-with-image "describe"
                                       [(ImageContent.init @"image/png"
                                                           @"IMGDATA")])
          req (LLM.chat-request "claude-sonnet-4-20250514" [msg] 100 0.5)
          body (Anthropic.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "messages")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just m)
                  (match (JSON.get &m "content")
                    (Maybe.Just content)
                      (and (JSON.arr? &content)
                           (match (JSON.nth &content 1)
                             (Maybe.Just img-part)
                               (and
                                 (= &(llm-json-str &img-part &[@"type"]) "image")
                                 (=
                                   &(llm-json-str &img-part &[@"source" @"type"])
                                   "base64"))
                             _ false))
                    _ false)
                _ false)
            _ false)
        _ false))
    "Anthropic serializes images with source.type=base64")

  (assert-true test
    (let [msg (Message.user-with-image "describe"
                                       [(ImageContent.init @"image/png"
                                                           @"IMGDATA")])
          req (LLM.chat-request "claude-sonnet-4-20250514" [msg] 100 0.5)
          body (Anthropic.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "messages")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just m)
                  (match (JSON.get &m "content")
                    (Maybe.Just content)
                      (match (JSON.nth &content 1)
                        (Maybe.Just img-part)
                          (and
                            (=
                              &(llm-json-str &img-part
                                             &[@"source" @"media_type"])
                              "image/png")
                            (=
                              &(llm-json-str &img-part &[@"source" @"data"])
                              "IMGDATA"))
                        _ false)
                    _ false)
                _ false)
            _ false)
        _ false))
    "Anthropic image source has correct media_type and data")

  ; =========================================================================
  ; Ollama image serialization
  ; =========================================================================

  (assert-true test
    (let [msg (Message.user-with-image "what is this?"
                                       [(ImageContent.init @"image/png"
                                                           @"OLLAMADATA")])
          req (LLM.chat-request "llava" [msg] 100 0.5)
          body (Ollama.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "messages")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just m)
                  (and
                    (= &(llm-json-str &m &[@"content"]) "what is this?")
                    (match (JSON.get &m "images")
                      (Maybe.Just imgs)
                        (match (JSON.nth &imgs 0)
                          (Maybe.Just img)
                            (= &(Maybe.from (JSON.as-str &img) @"") "OLLAMADATA")
                          _ false)
                      _ false))
                _ false)
            _ false)
        _ false))
    "Ollama serializes images as separate images array with base64 strings")

  (assert-true test
    (let [msg (Message.user "text only")
          req (LLM.chat-request "llava" [msg] 100 0.5)
          body (Ollama.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "messages")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just m)
                  (match (JSON.get &m "images")
                    (Maybe.Just _) false
                    (Maybe.Nothing) true)
                _ false)
            _ false)
        _ false))
    "Ollama omits images field for text-only messages")

  ; =========================================================================
  ; Gemini image serialization
  ; =========================================================================

  (assert-true test
    (let [msg (Message.user-with-image "describe"
                                       [(ImageContent.init @"image/jpeg"
                                                           @"GEMDATA")])
          req (LLM.chat-request "gemini-pro-vision" [msg] 100 0.5)
          body (Gemini.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "contents")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just entry)
                  (match (JSON.get &entry "parts")
                    (Maybe.Just parts)
                      (and
                        (match (JSON.nth &parts 0)
                          (Maybe.Just text-part)
                            (= &(llm-json-str &text-part &[@"text"]) "describe")
                          _ false)
                        (match (JSON.nth &parts 1)
                          (Maybe.Just img-part)
                            (and
                              (=
                                &(llm-json-str &img-part
                                               &[@"inlineData" @"mimeType"])
                                "image/jpeg")
                              (=
                                &(llm-json-str &img-part
                                               &[@"inlineData" @"data"])
                                "GEMDATA"))
                          _ false))
                    _ false)
                _ false)
            _ false)
        _ false))
    "Gemini serializes images as inlineData parts")

  ; =========================================================================
  ; Multiple images
  ; =========================================================================

  (assert-true test
    (let [msg (Message.user-with-image "compare"
                                       [(ImageContent.init @"image/png" @"IMG1")
                                        (ImageContent.init @"image/jpeg" @"IMG2")])
          req (LLM.chat-request "gpt-4o" [msg] 100 0.5)
          body (OpenAI.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "messages")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just m)
                  (match (JSON.get &m "content")
                    (Maybe.Just content)
                      (match (JSON.as-arr &content)
                        (Maybe.Just parts) (= (Array.length &parts) 3)
                        _ false)
                    _ false)
                _ false)
            _ false)
        _ false))
    "Multiple images produce text + N image parts (OpenAI)")

  ; =========================================================================
  ; llm-tool-calls-to-json helper
  ; =========================================================================

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"get_weather" @"{\"city\":\"Paris\"}")]
          j (llm-tool-calls-to-json &tcs)]
      (and (JSON.arr? &j)
           (match (JSON.nth &j 0)
             (Maybe.Just tc-json)
               (and
                 (= &(llm-json-str &tc-json &[@"id"]) "tc1")
                 (and
                   (= &(llm-json-str &tc-json &[@"type"]) "function")
                   (=
                     &(llm-json-str &tc-json &[@"function" @"name"])
                     "get_weather")))
             _ false)))
    "llm-tool-calls-to-json serializes tool calls to OpenAI format")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"f" @"not-json")]
          j (llm-tool-calls-to-json &tcs)]
      (match (JSON.nth &j 0)
        (Maybe.Just tc-json)
          (= &(llm-json-str &tc-json &[@"function" @"arguments"]) "not-json")
        _ false))
    "llm-tool-calls-to-json falls back to string for invalid JSON arguments")

  (assert-true test
    (let [entries [(JSON.entry @"role" (JSON.Str @"assistant"))]
          result (llm-append-tool-calls-entry entries &[])]
      (= (Array.length &result) 1))
    "llm-append-tool-calls-entry returns entries unchanged for empty tool calls")

  ; =========================================================================
  ; Message.to-json tool-call serialization (via helper)
  ; =========================================================================

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @""
                          [(ToolCall.init @"tc1" @"search" @"{\"q\":\"hi\"}")]
                          @""
                          [])
          j (Message.to-json &m)]
      (match (JSON.get &j "tool_calls")
        (Maybe.Just arr)
          (match (JSON.nth &arr 0)
            (Maybe.Just tc)
              (and (= &(llm-json-str &tc &[@"id"]) "tc1")
                   (= &(llm-json-str &tc &[@"function" @"name"]) "search"))
            _ false)
        _ false))
    "Message.to-json serializes tool calls via shared helper")

  ; =========================================================================
  ; Streaming parse-delta: SOH prefix on thinking tokens
  ; =========================================================================

  (assert-true test
    (let [line "data: {\"choices\":[{\"delta\":{\"content\":\"hello\"}}]}"]
      (match (OpenAI.parse-delta line) (Maybe.Just tok) (= &tok "hello") _ false))
    "OpenAI parse-delta returns regular content without SOH")

  (assert-true test
    (let [line "data: {\"choices\":[{\"delta\":{\"reasoning\":\"thinking\"}}]}"]
      (match (OpenAI.parse-delta line)
        (Maybe.Just tok)
          (and
            (= (Char.to-int (String.char-at &tok 0)) 1)
            (= &(String.suffix &tok 1) "thinking"))
        _ false))
    "OpenAI parse-delta prefixes reasoning tokens with SOH byte")

  (assert-true test
    (let [line "{\"message\":{\"content\":\"hello\"},\"done\":false}"]
      (match (Ollama.parse-delta line) (Maybe.Just tok) (= &tok "hello") _ false))
    "Ollama parse-delta returns regular content without SOH")

  (assert-true test
    (let [line "{\"message\":{\"thinking\":\"hmm\"},\"done\":false}"]
      (match (Ollama.parse-delta line)
        (Maybe.Just tok)
          (and
            (= (Char.to-int (String.char-at &tok 0)) 1)
            (= &(String.suffix &tok 1) "hmm"))
        _ false))
    "Ollama parse-delta prefixes thinking tokens with SOH byte")

  ; =========================================================================
  ; llm-loop-should-continue? — iteration control
  ; =========================================================================

  (assert-true test
    (not
      (let [r (LLMResponse.init @"done" @"stop" 5 3 [])]
        (llm-loop-should-continue? &r 0 10)))
    "llm-loop-should-continue? returns false with no tool calls")

  (assert-true test
    (let [r (LLMResponse.init @""
                              @"tool_calls"
                              5
                              3
                              [(ToolCall.init @"tc1" @"f" @"{}")])]
      (llm-loop-should-continue? &r 0 10))
    "llm-loop-should-continue? returns true with tool calls within limit")

  (assert-true test
    (not
      (let [r (LLMResponse.init @""
                                @"tool_calls"
                                5
                                3
                                [(ToolCall.init @"tc1" @"f" @"{}")])]
        (llm-loop-should-continue? &r 5 5)))
    "llm-loop-should-continue? returns false when iter equals max-iters")

  (assert-true test
    (not
      (let [r (LLMResponse.init @""
                                @"tool_calls"
                                5
                                3
                                [(ToolCall.init @"tc1" @"f" @"{}")])]
        (llm-loop-should-continue? &r 6 5)))
    "llm-loop-should-continue? returns false when iter exceeds max-iters")

  (assert-true test
    (not
      (let [r (LLMResponse.init @""
                                @"tool_calls"
                                5
                                3
                                [(ToolCall.init @"tc1" @"f" @"{}")])]
        (llm-loop-should-continue? &r 0 0)))
    "llm-loop-should-continue? returns false with max-iters 0")

  (assert-true test
    (let [r (LLMResponse.init @""
                              @"tool_calls"
                              5
                              3
                              [(ToolCall.init @"tc1" @"a" @"{}")
                               (ToolCall.init @"tc2" @"b" @"{}")])]
      (llm-loop-should-continue? &r 2 3))
    "llm-loop-should-continue? returns true with multiple tool calls")

  ; =========================================================================
  ; llm-collect-tool-results — handler dispatch
  ; =========================================================================

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"get_weather" @"{\"city\":\"Paris\"}")]
          handler (fn [tc] @"sunny")
          results (llm-collect-tool-results &tcs &handler)]
      (and (= (Array.length &results) 1)
           (and
             (= (Message.tool-call-id (Array.unsafe-nth &results 0)) "tc1")
             (= (Message.content (Array.unsafe-nth &results 0)) "sunny"))))
    "llm-collect-tool-results produces correct message for single tool call")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"get_weather" @"{}")
               (ToolCall.init @"tc2" @"get_time" @"{}")]
          handler (fn [tc]
            (if (= (ToolCall.name tc) "get_weather") @"sunny" @"12:00"))
          results (llm-collect-tool-results &tcs &handler)]
      (and (= (Array.length &results) 2)
           (and
             (= (Message.content (Array.unsafe-nth &results 0)) "sunny")
             (= (Message.content (Array.unsafe-nth &results 1)) "12:00"))))
    "llm-collect-tool-results dispatches handler by tool name")

  (assert-equal test
    0
    (let [tcs (the (Array ToolCall) [])
          handler (fn [tc] @"x")
          results (llm-collect-tool-results &tcs &handler)]
      (Array.length &results))
    "llm-collect-tool-results returns empty array for no tool calls")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"f" @"{}")]
          handler (fn [tc] @"ok")
          results (llm-collect-tool-results &tcs &handler)]
      (= &(Role.str (Message.role (Array.unsafe-nth &results 0))) "tool"))
    "llm-collect-tool-results produces messages with Tool role")

  (assert-true test
    (let [tcs [(ToolCall.init @"call_abc" @"f" @"{}")]
          handler (fn [tc] @"ok")
          results (llm-collect-tool-results &tcs &handler)]
      (= (Message.tool-call-id (Array.unsafe-nth &results 0)) "call_abc"))
    "llm-collect-tool-results preserves tool-call IDs")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"f" @"{\"x\":1}")]
          handler (fn [tc] (String.concat &[@"got:" @(ToolCall.arguments tc)]))
          results (llm-collect-tool-results &tcs &handler)]
      (= (Message.content (Array.unsafe-nth &results 0)) "got:{\"x\":1}"))
    "llm-collect-tool-results passes full ToolCall ref to handler")

  ; =========================================================================
  ; llm-apply-loop-step — message building
  ; =========================================================================

  (assert-true test
    (let [msgs [(Message.user "hello")]
          resp (LLMResponse.init @"I'll check"
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"tc1" @"get_weather" @"{}")])
          handler (fn [tc] @"sunny")
          result (llm-apply-loop-step msgs &resp &handler)]
      (and (= (Array.length &result) 3)
           (and
             (= &(Role.str (Message.role (Array.unsafe-nth &result 0))) "user")
             (and
               (=
                 &(Role.str (Message.role (Array.unsafe-nth &result 1)))
                 "assistant")
               (= &(Role.str (Message.role (Array.unsafe-nth &result 2))) "tool")))))
    "llm-apply-loop-step appends assistant message and tool results")

  (assert-true test
    (let [msgs (the (Array Message) [])
          resp (LLMResponse.init @"thinking..."
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"tc1" @"f" @"{}")])
          handler (fn [tc] @"ok")
          result (llm-apply-loop-step msgs &resp &handler)]
      (= (Message.content (Array.unsafe-nth &result 0)) "thinking..."))
    "llm-apply-loop-step preserves response content in assistant message")

  (assert-true test
    (let [msgs (the (Array Message) [])
          resp (LLMResponse.init @""
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"tc1" @"f" @"{}")])
          handler (fn [tc] @"ok")
          result (llm-apply-loop-step msgs &resp &handler)]
      (= (Array.length (Message.tool-calls (Array.unsafe-nth &result 0))) 1))
    "llm-apply-loop-step preserves tool calls in assistant message for history")

  (assert-true test
    (let [msgs [(Message.user "do stuff")]
          resp (LLMResponse.init @""
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"tc1" @"a" @"{}")
                                  (ToolCall.init @"tc2" @"b" @"{}")])
          handler (fn [tc] (if (= (ToolCall.name tc) "a") @"res-a" @"res-b"))
          result (llm-apply-loop-step msgs &resp &handler)]
      (and (= (Array.length &result) 4)
           (and
             (= (Message.content (Array.unsafe-nth &result 2)) "res-a")
             (= (Message.content (Array.unsafe-nth &result 3)) "res-b"))))
    "llm-apply-loop-step handles multiple tool calls in one step")

  (assert-true test
    (let [msgs (the (Array Message) [])
          resp (LLMResponse.init @""
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"call_123" @"f" @"{}")])
          handler (fn [tc] @"ok")
          result (llm-apply-loop-step msgs &resp &handler)]
      (= (Message.tool-call-id (Array.unsafe-nth &result 1)) "call_123"))
    "llm-apply-loop-step preserves tool-call IDs in result messages")

  ; =========================================================================
  ; LLM.chat-loop — error paths
  ; =========================================================================

  (assert-true test
    (let [config (ProviderConfig.init @"ollama" @"http://localhost:1" @"" @"")
          tools [(ToolDef.init @"f" @"desc" (JSON.obj []))]
          handler (fn [tc] @"result")]
      (match (LLM.chat-loop &config
                            "m"
                            [(Message.user "hi")]
                            10
                            0.5
                            &tools
                            handler
                            5)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.chat-loop returns Transport error on connection failure")

  (assert-true test
    (let [config (ProviderConfig.init @"ollama" @"http://localhost:1" @"" @"")
          tools [(ToolDef.init @"f" @"desc" (JSON.obj []))]
          handler (fn [tc] @"result")]
      (match (LLM.chat-loop &config
                            "m"
                            [(Message.user "hi")]
                            10
                            0.5
                            &tools
                            handler
                            0)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.chat-loop with max-iters 0 still chats once")

  (assert-true test
    (let [config (ProviderConfig.init @"bogus" @"http://x" @"" @"")
          tools [(ToolDef.init @"f" @"desc" (JSON.obj []))]
          handler (fn [tc] @"result")]
      (match (LLM.chat-loop &config
                            "m"
                            [(Message.user "hi")]
                            10
                            0.5
                            &tools
                            handler
                            5)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.chat-loop returns Transport error for unknown provider")

  ; =========================================================================
  ; Embedding types
  ; =========================================================================

  (assert-equal test
    "text-embedding-3-small"
    (EmbeddingRequest.model
      &(LLM.embedding-request "text-embedding-3-small" [@"hello"]))
    "LLM.embedding-request preserves model")

  (assert-equal test
    1
    (Array.length
      (EmbeddingRequest.input &(LLM.embedding-request "m" [@"hello"])))
    "LLM.embedding-request preserves input")

  ; =========================================================================
  ; OpenAI embedding serialization
  ; =========================================================================

  (assert-true test
    (let [req (LLM.embedding-request "text-embedding-3-small"
                                     [@"hello" @"world"])
          body (OpenAI.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (and
            (= &(llm-json-str &j &[@"model"]) "text-embedding-3-small")
            (match (JSON.get &j "input")
              (Maybe.Just arr)
                (and (JSON.arr? &arr)
                     (match (JSON.nth &arr 0)
                       (Maybe.Just v)
                         (= &(Maybe.from (JSON.as-str &v) @"") "hello")
                       _ false))
              _ false))
        _ false))
    "OpenAI.build-embedding-request produces valid JSON with model and input")

  (assert-true test
    (let [req (LLM.embedding-request "m" [@"a" @"b"])
          body (OpenAI.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "input")
            (Maybe.Just arr)
              (match (JSON.as-arr &arr)
                (Maybe.Just boxes) (= (Array.length &boxes) 2)
                _ false)
            _ false)
        _ false))
    "OpenAI.build-embedding-request includes all input strings")

  ; =========================================================================
  ; OpenAI embedding response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"data\":[{\"embedding\":[0.1,0.2,0.3],\"index\":0}],\"usage\":{\"total_tokens\":5}}"]
      (match (OpenAI.parse-embedding-response body)
        (Result.Success r)
          (and
            (= (Array.length (EmbeddingResponse.embeddings &r)) 1)
            (and
              (=
                (Array.length
                  (Array.unsafe-nth (EmbeddingResponse.embeddings &r) 0))
                3)
              (= @(EmbeddingResponse.total-tokens &r) 5)))
        _ false))
    "OpenAI.parse-embedding-response extracts embeddings and token count")

  (assert-true test
    (let [body "{\"data\":[{\"embedding\":[0.1],\"index\":0},{\"embedding\":[0.2],\"index\":1}],\"usage\":{\"total_tokens\":4}}"]
      (match (OpenAI.parse-embedding-response body)
        (Result.Success r)
          (= (Array.length (EmbeddingResponse.embeddings &r)) 2)
        _ false))
    "OpenAI.parse-embedding-response handles multiple embeddings")

  ; =========================================================================
  ; Ollama embedding serialization
  ; =========================================================================

  (assert-true test
    (let [req (LLM.embedding-request "all-minilm" [@"test"])
          body (Ollama.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (and
            (= &(llm-json-str &j &[@"model"]) "all-minilm")
            (match (JSON.get &j "input")
              (Maybe.Just arr) (JSON.arr? &arr)
              _ false))
        _ false))
    "Ollama.build-embedding-request produces valid JSON with model and input")

  ; =========================================================================
  ; Ollama embedding response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"model\":\"all-minilm\",\"embeddings\":[[0.1,0.2],[0.3,0.4]]}"]
      (match (Ollama.parse-embedding-response body)
        (Result.Success r)
          (and
            (= (Array.length (EmbeddingResponse.embeddings &r)) 2)
            (= @(EmbeddingResponse.total-tokens &r) 0))
        _ false))
    "Ollama.parse-embedding-response extracts embeddings with zero token count")

  ; =========================================================================
  ; Gemini embedding serialization
  ; =========================================================================

  (assert-true test
    (let [req (LLM.embedding-request "text-embedding-004" [@"hello"])
          body (Gemini.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "requests")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just r)
                  (and
                    (= &(llm-json-str &r &[@"model"])
                       "models/text-embedding-004")
                    (= &(llm-json-str &r &[@"content" @"parts"]) ""))
                _ false)
            _ false)
        _ false))
    "Gemini.build-embedding-request wraps input in batchEmbedContents format")

  (assert-true test
    (let [req (LLM.embedding-request "m" [@"a" @"b"])
          body (Gemini.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "requests")
            (Maybe.Just arr)
              (match (JSON.as-arr &arr)
                (Maybe.Just boxes) (= (Array.length &boxes) 2)
                _ false)
            _ false)
        _ false))
    "Gemini.build-embedding-request creates one request per input string")

  ; =========================================================================
  ; Gemini embedding response parsing
  ; =========================================================================

  (assert-true test
    (let [body "{\"embeddings\":[{\"values\":[0.5,0.6]},{\"values\":[0.7,0.8]}]}"]
      (match (Gemini.parse-embedding-response body)
        (Result.Success r)
          (and
            (= (Array.length (EmbeddingResponse.embeddings &r)) 2)
            (=
              (Array.length
                (Array.unsafe-nth (EmbeddingResponse.embeddings &r) 0))
              2))
        _ false))
    "Gemini.parse-embedding-response extracts embedding values")

  ; =========================================================================
  ; llm-json-doubles helper
  ; =========================================================================

  (assert-true test
    (let [j (JSON.Arr [(Box.init (JSON.Num 1.0)) (Box.init (JSON.Num 2.5))])
          result (llm-json-doubles &j)]
      (and (= (Array.length &result) 2) (= @(Array.unsafe-nth &result 0) 1.0)))
    "llm-json-doubles parses array of numbers")

  (assert-equal test
    0
    (Array.length &(llm-json-doubles &(JSON.Str @"not an array")))
    "llm-json-doubles returns empty array for non-array input")

  ; =========================================================================
  ; Embedding provider support
  ; =========================================================================

  (assert-true test
    (let [config (LLM.anthropic "sk-test")
          req (LLM.embedding-request "m" [@"hi"])]
      (match (LLM.embed &config &req)
        (Result.Error err)
          (match err
            (LLMError.Transport msg)
              (String.contains-string? &msg "does not support embeddings")
            _ false)
        _ false))
    "LLM.embed returns Transport error for Anthropic (no embeddings)")

  (assert-true test
    (let [config (ProviderConfig.init @"bogus" @"http://x" @"" @"")
          req (LLM.embedding-request "m" [@"hi"])]
      (match (LLM.embed &config &req)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.embed returns Transport error for unknown provider")

  ; =========================================================================
  ; Embedding transport error on connection failure
  ; =========================================================================

  (assert-true test
    (let [config (ProviderConfig.init @"ollama" @"http://localhost:1" @"" @"")
          req (LLM.embedding-request "m" [@"hi"])]
      (match (LLM.embed &config &req)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.embed returns Transport error on connection failure")

  ; =========================================================================
  ; llm-embedding-provider? helper
  ; =========================================================================

  (assert-true test
    (and (llm-embedding-provider? "openai")
         (and (llm-embedding-provider? "ollama")
              (llm-embedding-provider? "gemini")))
    "llm-embedding-provider? returns true for supported providers")

  (assert-true test
    (not (llm-embedding-provider? "anthropic"))
    "llm-embedding-provider? returns false for anthropic"))
