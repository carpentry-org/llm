  (assert-true test
    (let [chunks (llm-stream-parse-event "bogus" "anything")]
      (match @(Array.unsafe-nth &chunks 0) (StreamChunk.ChunkSkip) true _ false))
    "llm-stream-parse-event returns ChunkSkip for unknown provider")

  (assert-true test
    (let [line "data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"call_a\",\"type\":\"function\",\"function\":{\"name\":\"get_weather\",\"arguments\":\"\"}},{\"index\":1,\"id\":\"call_b\",\"type\":\"function\",\"function\":{\"name\":\"get_time\",\"arguments\":\"\"}}]}}]}"
          chunks (OpenAI.parse-stream-event line)]
      (and (= (Array.length &chunks) 2)
           (and
             (match @(Array.unsafe-nth &chunks 0)
               (StreamChunk.ChunkToolStart id name _args)
                 (and (= &id "call_a") (= &name "get_weather"))
               _ false)
             (match @(Array.unsafe-nth &chunks 1)
               (StreamChunk.ChunkToolStart id name _args)
                 (and (= &id "call_b") (= &name "get_time"))
               _ false))))
    "OpenAI parse-stream-event returns multiple ChunkToolStart for parallel tool calls")

  (assert-true test
    (let [line "{\"message\":{\"role\":\"assistant\",\"content\":\"\",\"tool_calls\":[{\"id\":\"c1\",\"function\":{\"name\":\"get_weather\",\"arguments\":{\"city\":\"Paris\"}}},{\"id\":\"c2\",\"function\":{\"name\":\"get_time\",\"arguments\":{\"tz\":\"CET\"}}}]},\"done\":true}"
          chunks (Ollama.parse-stream-event line)]
      (and (= (Array.length &chunks) 2)
           (and
             (match @(Array.unsafe-nth &chunks 0)
               (StreamChunk.ChunkToolFull tc)
                 (= (ToolCall.name &tc) "get_weather")
               _ false)
             (match @(Array.unsafe-nth &chunks 1)
               (StreamChunk.ChunkToolFull tc) (= (ToolCall.name &tc) "get_time")
               _ false))))
    "Ollama parse-stream-event returns all tool calls from done message")

  (assert-true test
    (let [line "data: {\"candidates\":[{\"content\":{\"parts\":[{\"functionCall\":{\"name\":\"get_weather\",\"args\":{\"city\":\"Paris\"}}},{\"functionCall\":{\"name\":\"get_time\",\"args\":{\"tz\":\"CET\"}}}]}}]}"
          chunks (Gemini.parse-stream-event line)]
      (and (= (Array.length &chunks) 2)
           (and
             (match @(Array.unsafe-nth &chunks 0)
               (StreamChunk.ChunkToolFull tc)
                 (= (ToolCall.name &tc) "get_weather")
               _ false)
             (match @(Array.unsafe-nth &chunks 1)
               (StreamChunk.ChunkToolFull tc) (= (ToolCall.name &tc) "get_time")
               _ false))))
    "Gemini parse-stream-event returns all functionCall parts")

  (assert-true test
    (let-do [s (make-test-llm-stream "openai"
                                     @"data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"call_a\",\"type\":\"function\",\"function\":{\"name\":\"get_weather\",\"arguments\":\"{}\"}},{\"index\":1,\"id\":\"call_b\",\"type\":\"function\",\"function\":{\"name\":\"get_time\",\"arguments\":\"{}\"}}]}}]}
data: [DONE]
")
             ok true
             evt1 (LlmStream.poll-event &s)
             evt2 (LlmStream.poll-event &s)
             evt3 (LlmStream.poll-event &s)]
      (match evt1
        (Maybe.Just e1)
          (match e1
            (StreamEvent.ToolCallEvent tc)
              (when (or (/= (ToolCall.id &tc) "call_a")
                        (/= (ToolCall.name &tc) "get_weather"))
                (set! ok false))
            _ (set! ok false))
        _ (set! ok false))
      (match evt2
        (Maybe.Just e2)
          (match e2
            (StreamEvent.ToolCallEvent tc)
              (when (or (/= (ToolCall.id &tc) "call_b")
                        (/= (ToolCall.name &tc) "get_time"))
                (set! ok false))
            _ (set! ok false))
        _ (set! ok false))
      (match evt3 (Maybe.Nothing) () _ (set! ok false))
      (LlmStream.close s)
      ok)
    "poll-event yields two ToolCallEvents then Nothing for parallel OpenAI tool calls")

  (assert-true test
    (let [msg (Message.tool-result "get_weather" "sunny")
          j (gemini-message-to-json &msg)]
      (= &(llm-json-str &j &[@"role"]) "user"))
    "Gemini tool message uses role user instead of tool")

  (assert-true test
    (let [msg (Message.tool-result "get_weather" "sunny")
          j (gemini-message-to-json &msg)]
      (match (JSON.get &j "parts")
        (Maybe.Just parts)
          (match (JSON.nth &parts 0)
            (Maybe.Just part)
              (=
                &(llm-json-str &part &[@"functionResponse" @"name"])
                "get_weather")
            _ false)
        _ false))
    "Gemini tool message has functionResponse with correct name")

  (assert-true test
    (let [msg (Message.tool-result "get_weather" "sunny")
          j (gemini-message-to-json &msg)]
      (match (JSON.get &j "parts")
        (Maybe.Just parts)
          (match (JSON.nth &parts 0)
            (Maybe.Just part)
              (=
                &(llm-json-str &part
                               &[@"functionResponse" @"response" @"result"])
                "sunny")
            _ false)
        _ false))
    "Gemini tool message wraps plain text in result object")

  (assert-true test
    (let [msg (Message.tool-result "f" "{\"temp\":22}")
          j (gemini-message-to-json &msg)]
      (match (JSON.get &j "parts")
        (Maybe.Just parts)
          (match (JSON.nth &parts 0)
            (Maybe.Just part)
              (match (JSON.get-in &part
                                  &[@"functionResponse" @"response" @"temp"])
                (Maybe.Just v) (= (Maybe.from (JSON.as-num &v) 0.0) 22.0)
                _ false)
            _ false)
        _ false))
    "Gemini tool message parses JSON content as response object")

  (assert-true test
    (let [msg (Message.assistant "hello")
          j (gemini-message-to-json &msg)]
      (= &(llm-json-str &j &[@"role"]) "model"))
    "Gemini assistant message uses role model")

  (assert-true test
    (let [msg (Message.init (Role.Assistant)
                            @""
                            [(ToolCall.init @""
                                            @"get_weather"
                                            @"{\"city\":\"Paris\"}")]
                            @""
                            [])
          j (gemini-message-to-json &msg)]
      (match (JSON.get &j "parts")
        (Maybe.Just parts)
          (match (JSON.nth &parts 0)
            (Maybe.Just part)
              (= &(llm-json-str &part &[@"functionCall" @"name"]) "get_weather")
            _ false)
        _ false))
    "Gemini assistant message serializes tool calls as functionCall parts")

  (assert-true test
    (let [msg (Message.init (Role.Assistant)
                            @""
                            [(ToolCall.init @""
                                            @"get_weather"
                                            @"{\"city\":\"Paris\"}")]
                            @""
                            [])
          j (gemini-message-to-json &msg)]
      (match (JSON.get &j "parts")
        (Maybe.Just parts)
          (match (JSON.nth &parts 0)
            (Maybe.Just part)
              (=
                &(llm-json-str &part &[@"functionCall" @"args" @"city"])
                "Paris")
            _ false)
        _ false))
    "Gemini functionCall includes parsed args")

  (assert-true test
    (let [tcs [(ToolCall.init @"" @"get_weather" @"{}")]
          handler (fn [tc] @"sunny")
          results (llm-collect-tool-results &tcs &handler)]
      (= (Message.tool-call-id (Array.unsafe-nth &results 0)) "get_weather"))
    "llm-collect-tool-results uses tool name when ID is empty")

  (assert-true test
    (let [tcs [(ToolCall.init @"call_123" @"get_weather" @"{}")]
          handler (fn [tc] @"sunny")
          results (llm-collect-tool-results &tcs &handler)]
      (= (Message.tool-call-id (Array.unsafe-nth &results 0)) "call_123"))
    "llm-collect-tool-results prefers call ID when present")

  (assert-true test
    (let [req (LLM.chat-request "gemini-pro"
                                [(Message.user "weather?")
                                 (Message.tool-result "get_weather" "sunny")]
                                100
                                0.5)
          body (Gemini.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "contents")
            (Maybe.Just arr)
              (match (JSON.nth &arr 1)
                (Maybe.Just entry)
                  (and
                    (= &(llm-json-str &entry &[@"role"]) "user")
                    (match (JSON.get &entry "parts")
                      (Maybe.Just parts)
                        (match (JSON.nth &parts 0)
                          (Maybe.Just part)
                            (=
                              &(llm-json-str &part
                                             &[@"functionResponse" @"name"])
                              "get_weather")
                          _ false)
                      _ false))
                _ false)
            _ false)
        _ false))
    "Gemini build-request serializes tool-result as functionResponse")

  (assert-true test
    (let [m (Message.tool-result "tc1" "sunny")
          j (llm-message-to-anthropic-json &m)]
      (= &(llm-json-str &j &[@"role"]) "user"))
    "Anthropic tool-result message has role=user")

  (assert-true test
    (let [m (Message.tool-result "tc1" "sunny")
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.nth &arr 0)
            (Maybe.Just block)
              (= &(llm-json-str &block &[@"type"]) "tool_result")
            _ false)
        _ false))
    "Anthropic tool-result message content has type=tool_result")

  (assert-true test
    (let [m (Message.tool-result "call_abc" "result text")
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.nth &arr 0)
            (Maybe.Just block)
              (= &(llm-json-str &block &[@"tool_use_id"]) "call_abc")
            _ false)
        _ false))
    "Anthropic tool-result message uses tool_use_id (not tool_call_id)")

  (assert-true test
    (let [m (Message.tool-result "tc1" "the answer is 42")
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.nth &arr 0)
            (Maybe.Just block)
              (= &(llm-json-str &block &[@"content"]) "the answer is 42")
            _ false)
        _ false))
    "Anthropic tool-result message preserves result content")

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @"I'll check"
                          [(ToolCall.init @"tc1"
                                          @"get_weather"
                                          @"{\"city\":\"Paris\"}")]
                          @""
                          [])
          j (llm-message-to-anthropic-json &m)]
      (= &(llm-json-str &j &[@"role"]) "assistant"))
    "Anthropic assistant+tool-calls message has role=assistant")

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @"I'll check"
                          [(ToolCall.init @"tc1"
                                          @"get_weather"
                                          @"{\"city\":\"Paris\"}")]
                          @""
                          [])
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.nth &arr 0)
            (Maybe.Just block)
              (and
                (= &(llm-json-str &block &[@"type"]) "text")
                (= &(llm-json-str &block &[@"text"]) "I'll check"))
            _ false)
        _ false))
    "Anthropic assistant+tool-calls has text block first")

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @"I'll check"
                          [(ToolCall.init @"tc1"
                                          @"get_weather"
                                          @"{\"city\":\"Paris\"}")]
                          @""
                          [])
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.nth &arr 1)
            (Maybe.Just block)
              (and
                (= &(llm-json-str &block &[@"type"]) "tool_use")
                (and
                  (= &(llm-json-str &block &[@"id"]) "tc1")
                  (= &(llm-json-str &block &[@"name"]) "get_weather")))
            _ false)
        _ false))
    "Anthropic assistant+tool-calls has tool_use block with id and name")

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @"I'll check"
                          [(ToolCall.init @"tc1"
                                          @"get_weather"
                                          @"{\"city\":\"Paris\"}")]
                          @""
                          [])
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.nth &arr 1)
            (Maybe.Just block)
              (match (JSON.get &block "input")
                (Maybe.Just inp) (= &(llm-json-str &inp &[@"city"]) "Paris")
                _ false)
            _ false)
        _ false))
    "Anthropic tool_use block has parsed input JSON")

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @""
                          [(ToolCall.init @"tc1" @"f" @"{}")]
                          @""
                          [])
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.as-arr &arr)
            (Maybe.Just boxes) (= (Array.length &boxes) 1)
            _ false)
        _ false))
    "Anthropic omits text block when assistant content is empty")

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @""
                          [(ToolCall.init @"tc1" @"a" @"{}")
                           (ToolCall.init @"tc2" @"b" @"{}")]
                          @""
                          [])
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.as-arr &arr)
            (Maybe.Just boxes) (= (Array.length &boxes) 2)
            _ false)
        _ false))
    "Anthropic serializes multiple tool_use blocks")

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @""
                          [(ToolCall.init @"tc1" @"f" @"not-json")]
                          @""
                          [])
          j (llm-message-to-anthropic-json &m)]
      (match (JSON.get &j "content")
        (Maybe.Just arr)
          (match (JSON.nth &arr 0)
            (Maybe.Just block)
              (match (JSON.get &block "input")
                (Maybe.Just inp)
                  (= &(Maybe.from (JSON.as-str &inp) @"") "not-json")
                _ false)
            _ false)
        _ false))
    "Anthropic tool_use falls back to string for invalid JSON arguments")

  (assert-true test
    (let [m (Message.user "hello")
          j (llm-message-to-anthropic-json &m)]
      (and
        (match (JSON.get &j "tool_calls")
          (Maybe.Just _) false
          (Maybe.Nothing) true)
        (match (JSON.get &j "tool_call_id")
          (Maybe.Just _) false
          (Maybe.Nothing) true)))
    "Anthropic regular user message has no tool_calls or tool_call_id keys")

  (assert-true test
    (let [msgs [(Message.user "weather?")
                (Message.init (Role.Assistant)
                              @""
                              [(ToolCall.init @"tc1" @"get_weather" @"{}")]
                              @""
                              [])
                (Message.tool-result "tc1" "sunny")]
          req (LLM.chat-request-with-tools "claude-sonnet-4-20250514"
                                           msgs
                                           100
                                           0.5
                                           [(ToolDef.init @"get_weather"
                                                          @"Get weather"
                                                          (JSON.obj []))])
          body (Anthropic.build-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "messages")
            (Maybe.Just arr)
              (and ; First message: user
                   (match (JSON.nth &arr 0)
                     (Maybe.Just m) (= &(llm-json-str &m &[@"role"]) "user")
                     _ false)
                   (and
                     ; Second message: assistant with tool_use content
                     (match (JSON.nth &arr 1)
                       (Maybe.Just m)
                         (match (JSON.get &m "content")
                           (Maybe.Just content)
                             (match (JSON.nth &content 0)
                               (Maybe.Just block)
                                 (= &(llm-json-str &block &[@"type"]) "tool_use")
                               _ false)
                           _ false)
                       _ false)
                     ; Third message: user with tool_result content
                     (match (JSON.nth &arr 2)
                       (Maybe.Just m)
                         (and (= &(llm-json-str &m &[@"role"]) "user")
                              (match (JSON.get &m "content")
                                (Maybe.Just content)
                                  (match (JSON.nth &content 0)
                                    (Maybe.Just block)
                                      (= &(llm-json-str &block &[@"type"])
                                         "tool_result")
                                    _ false)
                                _ false))
                       _ false)))
            _ false)
        _ false))
    "Anthropic full multi-turn tool conversation uses correct wire format")

  (assert-true test
    (let [body "{\"content\":[{\"type\":\"text\",\"text\":\"Let me check\"},{\"type\":\"tool_use\",\"id\":\"tc1\",\"name\":\"get_weather\",\"input\":{\"city\":\"Paris\"}}],\"stop_reason\":\"tool_use\",\"usage\":{\"input_tokens\":10,\"output_tokens\":5}}"]
      (match (Anthropic.parse-response body)
        (Result.Success r)
          (and
            (= (LLMResponse.content &r) "Let me check")
            (and
              (= (Array.length (LLMResponse.tool-calls &r)) 1)
              (=
                (ToolCall.name (Array.unsafe-nth (LLMResponse.tool-calls &r) 0))
                "get_weather")))
        _ false))
    "Anthropic.parse-response extracts both text content and tool calls")

  (assert-true test
    (let [line "data: {\"type\":\"content_block_delta\",\"delta\":{\"type\":\"text_delta\",\"text\":\"hello\"}}"]
      (match (Anthropic.parse-delta line)
        (Maybe.Just tok) (= &tok "hello")
        _ false))
    "Anthropic parse-delta returns regular text_delta content")

  (assert-true test
    (let [line "data: {\"type\":\"content_block_delta\",\"delta\":{\"type\":\"thinking_delta\",\"thinking\":\"let me think\"}}"]
      (match (Anthropic.parse-delta line)
        (Maybe.Just tok)
          (and
            (= (Char.to-int (String.char-at &tok 0)) 1)
            (= &(String.suffix &tok 1) "let me think"))
        _ false))
    "Anthropic parse-delta prefixes thinking_delta tokens with SOH byte")

  (assert-true test
    (let [line "data: {\"type\":\"content_block_delta\",\"delta\":{\"type\":\"thinking_delta\",\"thinking\":\"\"}}"]
      (match (Anthropic.parse-delta line) (Maybe.Nothing) true _ false))
    "Anthropic parse-delta returns Nothing for empty thinking_delta")

  (assert-true test
    (let [line "data: {\"type\":\"content_block_delta\",\"delta\":{\"type\":\"text_delta\",\"text\":\"\"}}"]
      (match (Anthropic.parse-delta line) (Maybe.Nothing) true _ false))
    "Anthropic parse-delta returns Nothing for empty text_delta")

  (assert-true test
    (let [line "data: {\"type\":\"content_block_start\",\"content_block\":{\"type\":\"text\"}}"]
      (match (Anthropic.parse-delta line) (Maybe.Nothing) true _ false))
    "Anthropic parse-delta ignores non-delta events")

  (assert-true test
    (match (Anthropic.parse-delta "event: message_start")
      (Maybe.Nothing) true
      _ false)
    "Anthropic parse-delta ignores non-data lines")

  (assert-true test
    (let [line "data: {\"candidates\":[{\"content\":{\"parts\":[{\"text\":\"hello\"}]}}]}"]
      (match (Gemini.parse-delta line) (Maybe.Just tok) (= &tok "hello") _ false))
    "Gemini parse-delta returns regular content without SOH")

  (assert-true test
    (let [line "data: {\"candidates\":[{\"content\":{\"parts\":[{\"thought\":true,\"text\":\"hmm\"}]}}]}"]
      (match (Gemini.parse-delta line)
        (Maybe.Just tok)
          (and
            (= (Char.to-int (String.char-at &tok 0)) 1)
            (= &(String.suffix &tok 1) "hmm"))
        _ false))
    "Gemini parse-delta prefixes thought=true tokens with SOH byte")

  (assert-true test
    (let [line "data: {\"candidates\":[{\"content\":{\"parts\":[{\"thought\":false,\"text\":\"regular\"}]}}]}"]
      (match (Gemini.parse-delta line)
        (Maybe.Just tok) (= &tok "regular")
        _ false))
    "Gemini parse-delta returns regular content for thought=false")

  (assert-true test
    (let [line "data: {\"candidates\":[{\"content\":{\"parts\":[{\"thought\":true,\"text\":\"\"}]}}]}"]
      (match (Gemini.parse-delta line) (Maybe.Nothing) true _ false))
    "Gemini parse-delta returns Nothing for empty thought text"))
