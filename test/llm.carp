                                   "base64"))
                             _ false))
                    _ false)
                _ false)
            _ false)
        _ false))
    "Anthropic serializes images with source.type=base64")

  (assert-true test
    (let [msg (Message.user-with-image "describe"
                                       [(ImageContent.init @"image/png"
                                                           @"IMGDATA")])
          req (LLM.chat-request "claude-sonnet-4-20250514" [msg] 100 0.5)
