  (assert-true test
    (let [chunks (Gemini.parse-stream-event
            "data: {\"candidates\":[{\"finishReason\":\"STOP\"}]}")]
      (match @(Array.unsafe-nth &chunks 0) (StreamChunk.ChunkDone) true _ false))
    "Gemini parse-stream-event returns ChunkDone for finishReason without parts")

  (assert-true test
    (let [tools [(ToolDef.init @"f" @"desc" (JSON.obj []))]
          req (LLM.chat-request-with-tools "gpt-4"
                                           [(Message.user "hi")]
                                           100
                                           0.5
                                           tools)
          body (OpenAI.build-stream-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (and
            (match (JSON.get &j "stream")
              (Maybe.Just s) (Maybe.from (JSON.as-bool &s) false)
              _ false)
            (match (JSON.get &j "tools")
              (Maybe.Just arr) (JSON.arr? &arr)
              _ false))
        _ false))
    "OpenAI streaming request includes tools")

  (assert-true test
    (let [tools [(ToolDef.init @"f"
                               @"desc"
                               (JSON.obj
