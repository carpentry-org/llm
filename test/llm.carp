                        _ false)
                    _ false)
                _ false)
            _ false)
        _ false))
    "Multiple images produce text + N image parts (OpenAI)")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"get_weather" @"{\"city\":\"Paris\"}")]
          j (llm-tool-calls-to-json &tcs)]
      (and (JSON.arr? &j)
           (match (JSON.nth &j 0)
             (Maybe.Just tc-json)
               (and
                 (= &(llm-json-str &tc-json &[@"id"]) "tc1")
                 (and
                   (= &(llm-json-str &tc-json &[@"type"]) "function")
                   (=
                     &(llm-json-str &tc-json &[@"function" @"name"])
                     "get_weather")))
             _ false)))
    "llm-tool-calls-to-json serializes tool calls to OpenAI format")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"f" @"not-json")]
          j (llm-tool-calls-to-json &tcs)]
      (match (JSON.nth &j 0)
        (Maybe.Just tc-json)
          (= &(llm-json-str &tc-json &[@"function" @"arguments"]) "not-json")
        _ false))
    "llm-tool-calls-to-json falls back to string for invalid JSON arguments")

  (assert-true test
    (let [entries [(JSON.entry @"role" (JSON.Str @"assistant"))]
          result (llm-append-tool-calls-entry entries &[])]
      (= (Array.length &result) 1))
    "llm-append-tool-calls-entry returns entries unchanged for empty tool calls")

  (assert-true test
    (let [m (Message.init (Role.Assistant)
                          @""
                          [(ToolCall.init @"tc1" @"search" @"{\"q\":\"hi\"}")]
                          @""
                          [])
          j (Message.to-json &m)]
      (match (JSON.get &j "tool_calls")
        (Maybe.Just arr)
          (match (JSON.nth &arr 0)
            (Maybe.Just tc)
              (and (= &(llm-json-str &tc &[@"id"]) "tc1")
                   (= &(llm-json-str &tc &[@"function" @"name"]) "search"))
            _ false)
        _ false))
    "Message.to-json serializes tool calls via shared helper")

  (assert-true test
    (let [line "data: {\"choices\":[{\"delta\":{\"content\":\"hello\"}}]}"]
      (match (OpenAI.parse-delta line) (Maybe.Just tok) (= &tok "hello") _ false))
    "OpenAI parse-delta returns regular content without SOH")

  (assert-true test
    (let [line "data: {\"choices\":[{\"delta\":{\"reasoning\":\"thinking\"}}]}"]
      (match (OpenAI.parse-delta line)
        (Maybe.Just tok)
          (and
            (= (Char.to-int (String.char-at &tok 0)) 1)
            (= &(String.suffix &tok 1) "thinking"))
        _ false))
    "OpenAI parse-delta prefixes reasoning tokens with SOH byte")

  (assert-true test
    (let [line "{\"message\":{\"content\":\"hello\"},\"done\":false}"]
      (match (Ollama.parse-delta line) (Maybe.Just tok) (= &tok "hello") _ false))
    "Ollama parse-delta returns regular content without SOH")

  (assert-true test
    (let [line "{\"message\":{\"thinking\":\"hmm\"},\"done\":false}"]
      (match (Ollama.parse-delta line)
        (Maybe.Just tok)
          (and
            (= (Char.to-int (String.char-at &tok 0)) 1)
            (= &(String.suffix &tok 1) "hmm"))
        _ false))
    "Ollama parse-delta prefixes thinking tokens with SOH byte")

  (assert-true test
    (not
      (let [r (LLMResponse.init @"done" @"stop" 5 3 [])]
        (llm-loop-should-continue? &r 0 10)))
    "llm-loop-should-continue? returns false with no tool calls")

  (assert-true test
    (let [r (LLMResponse.init @""
                              @"tool_calls"
                              5
                              3
                              [(ToolCall.init @"tc1" @"f" @"{}")])]
      (llm-loop-should-continue? &r 0 10))
    "llm-loop-should-continue? returns true with tool calls within limit")

  (assert-true test
    (not
      (let [r (LLMResponse.init @""
                                @"tool_calls"
                                5
                                3
                                [(ToolCall.init @"tc1" @"f" @"{}")])]
        (llm-loop-should-continue? &r 5 5)))
    "llm-loop-should-continue? returns false when iter equals max-iters")

  (assert-true test
    (not
      (let [r (LLMResponse.init @""
                                @"tool_calls"
                                5
                                3
                                [(ToolCall.init @"tc1" @"f" @"{}")])]
        (llm-loop-should-continue? &r 6 5)))
    "llm-loop-should-continue? returns false when iter exceeds max-iters")

  (assert-true test
    (not
      (let [r (LLMResponse.init @""
                                @"tool_calls"
                                5
                                3
                                [(ToolCall.init @"tc1" @"f" @"{}")])]
        (llm-loop-should-continue? &r 0 0)))
    "llm-loop-should-continue? returns false with max-iters 0")

  (assert-true test
    (let [r (LLMResponse.init @""
                              @"tool_calls"
                              5
                              3
                              [(ToolCall.init @"tc1" @"a" @"{}")
                               (ToolCall.init @"tc2" @"b" @"{}")])]
      (llm-loop-should-continue? &r 2 3))
    "llm-loop-should-continue? returns true with multiple tool calls")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"get_weather" @"{\"city\":\"Paris\"}")]
          handler (fn [tc] @"sunny")
          results (llm-collect-tool-results &tcs &handler)]
      (and (= (Array.length &results) 1)
           (and
             (= (Message.tool-call-id (Array.unsafe-nth &results 0)) "tc1")
             (= (Message.content (Array.unsafe-nth &results 0)) "sunny"))))
    "llm-collect-tool-results produces correct message for single tool call")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"get_weather" @"{}")
               (ToolCall.init @"tc2" @"get_time" @"{}")]
          handler (fn [tc]
            (if (= (ToolCall.name tc) "get_weather") @"sunny" @"12:00"))
          results (llm-collect-tool-results &tcs &handler)]
      (and (= (Array.length &results) 2)
           (and
             (= (Message.content (Array.unsafe-nth &results 0)) "sunny")
             (= (Message.content (Array.unsafe-nth &results 1)) "12:00"))))
    "llm-collect-tool-results dispatches handler by tool name")

  (assert-equal test
    0
    (let [tcs (the (Array ToolCall) [])
          handler (fn [tc] @"x")
          results (llm-collect-tool-results &tcs &handler)]
      (Array.length &results))
    "llm-collect-tool-results returns empty array for no tool calls")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"f" @"{}")]
          handler (fn [tc] @"ok")
          results (llm-collect-tool-results &tcs &handler)]
      (= &(Role.str (Message.role (Array.unsafe-nth &results 0))) "tool"))
    "llm-collect-tool-results produces messages with Tool role")

  (assert-true test
    (let [tcs [(ToolCall.init @"call_abc" @"f" @"{}")]
          handler (fn [tc] @"ok")
          results (llm-collect-tool-results &tcs &handler)]
      (= (Message.tool-call-id (Array.unsafe-nth &results 0)) "call_abc"))
    "llm-collect-tool-results preserves tool-call IDs")

  (assert-true test
    (let [tcs [(ToolCall.init @"tc1" @"f" @"{\"x\":1}")]
          handler (fn [tc] (String.concat &[@"got:" @(ToolCall.arguments tc)]))
          results (llm-collect-tool-results &tcs &handler)]
      (= (Message.content (Array.unsafe-nth &results 0)) "got:{\"x\":1}"))
    "llm-collect-tool-results passes full ToolCall ref to handler")

  (assert-true test
    (let [msgs [(Message.user "hello")]
          resp (LLMResponse.init @"I'll check"
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"tc1" @"get_weather" @"{}")])
          handler (fn [tc] @"sunny")
          result (llm-apply-loop-step msgs &resp &handler)]
      (and (= (Array.length &result) 3)
           (and
             (= &(Role.str (Message.role (Array.unsafe-nth &result 0))) "user")
             (and
               (=
                 &(Role.str (Message.role (Array.unsafe-nth &result 1)))
                 "assistant")
               (= &(Role.str (Message.role (Array.unsafe-nth &result 2))) "tool")))))
    "llm-apply-loop-step appends assistant message and tool results")

  (assert-true test
    (let [msgs (the (Array Message) [])
          resp (LLMResponse.init @"thinking..."
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"tc1" @"f" @"{}")])
          handler (fn [tc] @"ok")
          result (llm-apply-loop-step msgs &resp &handler)]
      (= (Message.content (Array.unsafe-nth &result 0)) "thinking..."))
    "llm-apply-loop-step preserves response content in assistant message")

  (assert-true test
    (let [msgs (the (Array Message) [])
          resp (LLMResponse.init @""
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"tc1" @"f" @"{}")])
          handler (fn [tc] @"ok")
          result (llm-apply-loop-step msgs &resp &handler)]
      (= (Array.length (Message.tool-calls (Array.unsafe-nth &result 0))) 1))
    "llm-apply-loop-step preserves tool calls in assistant message for history")

  (assert-true test
    (let [msgs [(Message.user "do stuff")]
          resp (LLMResponse.init @""
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"tc1" @"a" @"{}")
                                  (ToolCall.init @"tc2" @"b" @"{}")])
          handler (fn [tc] (if (= (ToolCall.name tc) "a") @"res-a" @"res-b"))
          result (llm-apply-loop-step msgs &resp &handler)]
      (and (= (Array.length &result) 4)
           (and
             (= (Message.content (Array.unsafe-nth &result 2)) "res-a")
             (= (Message.content (Array.unsafe-nth &result 3)) "res-b"))))
    "llm-apply-loop-step handles multiple tool calls in one step")

  (assert-true test
    (let [msgs (the (Array Message) [])
          resp (LLMResponse.init @""
                                 @"tool_calls"
                                 5
                                 3
                                 [(ToolCall.init @"call_123" @"f" @"{}")])
          handler (fn [tc] @"ok")
          result (llm-apply-loop-step msgs &resp &handler)]
      (= (Message.tool-call-id (Array.unsafe-nth &result 1)) "call_123"))
    "llm-apply-loop-step preserves tool-call IDs in result messages")

  (assert-true test
    (let [config (ProviderConfig.init @"ollama" @"http://localhost:1" @"" @"")
          tools [(ToolDef.init @"f" @"desc" (JSON.obj []))]
          handler (fn [tc] @"result")]
      (match (LLM.chat-loop &config
                            "m"
                            [(Message.user "hi")]
                            10
                            0.5
                            &tools
                            handler
                            5)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.chat-loop returns Transport error on connection failure")

  (assert-true test
    (let [config (ProviderConfig.init @"ollama" @"http://localhost:1" @"" @"")
          tools [(ToolDef.init @"f" @"desc" (JSON.obj []))]
          handler (fn [tc] @"result")]
      (match (LLM.chat-loop &config
                            "m"
                            [(Message.user "hi")]
                            10
                            0.5
                            &tools
                            handler
                            0)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.chat-loop with max-iters 0 still chats once")

  (assert-true test
    (let [config (ProviderConfig.init @"bogus" @"http://x" @"" @"")
          tools [(ToolDef.init @"f" @"desc" (JSON.obj []))]
          handler (fn [tc] @"result")]
      (match (LLM.chat-loop &config
                            "m"
                            [(Message.user "hi")]
                            10
                            0.5
                            &tools
                            handler
                            5)
        (Result.Error err) (match err (LLMError.Transport _) true _ false)
        _ false))
    "LLM.chat-loop returns Transport error for unknown provider")

  (assert-equal test
    "text-embedding-3-small"
    (EmbeddingRequest.model
      &(LLM.embedding-request "text-embedding-3-small" [@"hello"]))
    "LLM.embedding-request preserves model")

  (assert-equal test
    1
    (Array.length
      (EmbeddingRequest.input &(LLM.embedding-request "m" [@"hello"])))
    "LLM.embedding-request preserves input")

  (assert-true test
    (let [req (LLM.embedding-request "text-embedding-3-small"
                                     [@"hello" @"world"])
          body (OpenAI.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (and
            (= &(llm-json-str &j &[@"model"]) "text-embedding-3-small")
            (match (JSON.get &j "input")
              (Maybe.Just arr)
                (and (JSON.arr? &arr)
                     (match (JSON.nth &arr 0)
                       (Maybe.Just v)
                         (= &(Maybe.from (JSON.as-str &v) @"") "hello")
                       _ false))
              _ false))
        _ false))
    "OpenAI.build-embedding-request produces valid JSON with model and input")

  (assert-true test
    (let [req (LLM.embedding-request "m" [@"a" @"b"])
          body (OpenAI.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "input")
            (Maybe.Just arr)
              (match (JSON.as-arr &arr)
                (Maybe.Just boxes) (= (Array.length &boxes) 2)
                _ false)
            _ false)
        _ false))
    "OpenAI.build-embedding-request includes all input strings")

  (assert-true test
    (let [body "{\"data\":[{\"embedding\":[0.1,0.2,0.3],\"index\":0}],\"usage\":{\"total_tokens\":5}}"]
      (match (OpenAI.parse-embedding-response body)
        (Result.Success r)
          (and
            (= (Array.length (EmbeddingResponse.embeddings &r)) 1)
            (and
              (=
                (Array.length
                  (Array.unsafe-nth (EmbeddingResponse.embeddings &r) 0))
                3)
              (= @(EmbeddingResponse.total-tokens &r) 5)))
        _ false))
    "OpenAI.parse-embedding-response extracts embeddings and token count")

  (assert-true test
    (let [body "{\"data\":[{\"embedding\":[0.1],\"index\":0},{\"embedding\":[0.2],\"index\":1}],\"usage\":{\"total_tokens\":4}}"]
      (match (OpenAI.parse-embedding-response body)
        (Result.Success r)
          (= (Array.length (EmbeddingResponse.embeddings &r)) 2)
        _ false))
    "OpenAI.parse-embedding-response handles multiple embeddings")

  (assert-true test
    (let [req (LLM.embedding-request "all-minilm" [@"test"])
          body (Ollama.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (and
            (= &(llm-json-str &j &[@"model"]) "all-minilm")
            (match (JSON.get &j "input")
              (Maybe.Just arr) (JSON.arr? &arr)
              _ false))
        _ false))
    "Ollama.build-embedding-request produces valid JSON with model and input")

  (assert-true test
    (let [body "{\"model\":\"all-minilm\",\"embeddings\":[[0.1,0.2],[0.3,0.4]]}"]
      (match (Ollama.parse-embedding-response body)
        (Result.Success r)
          (and
            (= (Array.length (EmbeddingResponse.embeddings &r)) 2)
            (= @(EmbeddingResponse.total-tokens &r) 0))
        _ false))
    "Ollama.parse-embedding-response extracts embeddings with zero token count")

  (assert-true test
    (let [req (LLM.embedding-request "text-embedding-004" [@"hello"])
          body (Gemini.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "requests")
            (Maybe.Just arr)
              (match (JSON.nth &arr 0)
                (Maybe.Just r)
                  (and
                    (= &(llm-json-str &r &[@"model"])
                       "models/text-embedding-004")
                    (= &(llm-json-str &r &[@"content" @"parts"]) ""))
                _ false)
            _ false)
        _ false))
    "Gemini.build-embedding-request wraps input in batchEmbedContents format")

  (assert-true test
    (let [req (LLM.embedding-request "m" [@"a" @"b"])
          body (Gemini.build-embedding-request &req)]
      (match (JSON.parse &body)
        (Result.Success j)
          (match (JSON.get &j "requests")
            (Maybe.Just arr)
              (match (JSON.as-arr &arr)
                (Maybe.Just boxes) (= (Array.length &boxes) 2)
                _ false)
            _ false)
        _ false))
    "Gemini.build-embedding-request creates one request per input string")

  (assert-true test
    (let [body "{\"embeddings\":[{\"values\":[0.5,0.6]},{\"values\":[0.7,0.8]}]}"]
      (match (Gemini.parse-embedding-response body)
        (Result.Success r)
          (and
